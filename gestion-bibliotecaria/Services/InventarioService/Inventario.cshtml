@page "/Inventario"
@model gestion_bibliotecaria.Pages.InventarioModel
@{
    ViewData["Title"] = "Gestión de Inventario - Ejemplares";
}

<h1>📦 Gestión de Inventario (Ejemplares)</h1>

<div class="mb-3">
    <a href="/Inventario/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Agregar Nuevo Ejemplar
    </a>
</div>

@if (!Model.Ejemplares.Any())
{
    <div class="alert alert-info">
        No hay ejemplares registrados en el inventario.
    </div>
}
else
{
    var total = Model.Ejemplares.Count;
    var disponibles = Model.Ejemplares.Count(e => e.Disponible && !e.DadoDeBaja);
    var noDisponibles = Model.Ejemplares.Count(e => !e.Disponible && !e.DadoDeBaja);
    var dadosDeBaja = Model.Ejemplares.Count(e => e.DadoDeBaja);

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Código Inventario</th>
                    <th>Libro</th>
                    <th>Estado Conservación</th>
                    <th>Disponible</th>
                    <th>Dado de Baja</th>
                    <th>Ubicación</th>
                    <th>Estado</th>
                    <th style="width: 200px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ejemplar in Model.Ejemplares)
                {
                    <tr class="@(ejemplar.DadoDeBaja ? "table-secondary" : "")">
                        <td>@ejemplar.EjemplarId</td>
                        <td><strong>@ejemplar.CodigoInventario</strong></td>
                        <td>
                            @if (Model.LibrosTitulos.TryGetValue(ejemplar.LibroId, out var tituloLibro))
                            {
                                <span>@tituloLibro</span>
                            }
                            else
                            {
                                <span class="text-muted">Libro #@ejemplar.LibroId</span>
                            }
                        </td>
                        <td>@(ejemplar.EstadoConservacion ?? "N/A")</td>
                        <td>
                            @if (ejemplar.Disponible)
                            {
                                <span class="badge bg-success">Disponible</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">No disponible</span>
                            }
                        </td>
                        <td>
                            @if (ejemplar.DadoDeBaja)
                            {
                                <span class="badge bg-danger">Sí</span>
                                @if (!string.IsNullOrEmpty(ejemplar.MotivoBaja))
                                {
                                    <br/><small class="text-muted">@ejemplar.MotivoBaja</small>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>
                        <td>@(ejemplar.Ubicacion ?? "N/A")</td>
                        <td>
                            @if (ejemplar.Estado)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a href="/Inventario/Edit/@ejemplar.EjemplarId"
                                   class="btn btn-sm btn-warning" title="Editar">
                                    ✏️
                                </a>
                                <a href="/Inventario/Delete/@ejemplar.EjemplarId"
                                   class="btn btn-sm btn-danger" title="Eliminar">
                                    🗑️
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <div class="row mt-3">
        <div class="col-md-3">
            <div class="alert alert-info">
                <strong>Total ejemplares:</strong> @total
            </div>
        </div>
        <div class="col-md-3">
            <div class="alert alert-success">
                <strong>Disponibles:</strong> @disponibles
            </div>
        </div>
        <div class="col-md-3">
            <div class="alert alert-warning">
                <strong>No disponibles:</strong> @noDisponibles
            </div>
        </div>
        <div class="col-md-3">
            <div class="alert alert-danger">
                <strong>Dados de baja:</strong> @dadosDeBaja
            </div>
        </div>
    </div>
}
