@page "/Libro/Edit/{id:int}"
@using System.Data
@model gestion_bibliotecaria.Pages.LibroEditModel
@{
    ViewData["Title"] = "Editar Libro";
}

<h1>Editar Libro</h1>

<form method="post">
    <input type="hidden" asp-for="LibroId" />
    <input type="hidden" asp-for="FechaRegistro" />

    <div class="mb-3">
        <label asp-for="AutorId" class="form-label">Autor</label>
        <select asp-for="AutorId" class="form-control" required>
            <option value="">Seleccione un autor...</option>
            @foreach (DataRow row in Model.Autores.Rows)
            {
                var autorId = (int)row["AutorId"];
                var nombres = row["Nombres"]?.ToString() ?? string.Empty;
                var apellidos = row["Apellidos"]?.ToString() ?? string.Empty;
                var nacionalidad = row["Nacionalidad"] as string;

                <option value="@autorId">
                    @apellidos, @nombres @(nacionalidad != null ? $"({nacionalidad})" : "")
                </option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Titulo" class="form-label">Título</label>
        <input asp-for="Titulo" class="form-control" required />
    </div>

    <div class="mb-3">
        <label asp-for="Editorial" class="form-label">Editorial</label>
        <input asp-for="Editorial" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Edicion" class="form-label">Edición</label>
        <input asp-for="Edicion" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="AñoPublicacion" class="form-label">Año de Publicación</label>
        <input asp-for="AñoPublicacion" class="form-control" type="number" 
               min="1000" max="2100" />
    </div>

    <div class="mb-3">
        <label asp-for="Descripcion" class="form-label">Descripción</label>
        <textarea asp-for="Descripcion" class="form-control" rows="4"></textarea>
    </div>

    <div class="mb-3">
        <div class="form-check">
            <input asp-for="Estado" class="form-check-input" type="checkbox" />
            <label asp-for="Estado" class="form-check-label">Activo en el sistema</label>
        </div>
    </div>

    <div class="mb-3">
        <button type="submit" class="btn btn-primary">Actualizar</button>
        <a href="/Libro" class="btn btn-secondary">Cancelar</a>
    </div>
</form>
