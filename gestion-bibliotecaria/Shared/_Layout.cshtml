@using gestion_bibliotecaria.Infrastructure.Security
@using Microsoft.AspNetCore.Http
@{
    var nombreUsuarioSesion = Context.Session.GetString(SessionKeys.NombreUsuario);
    var rolSesion = Context.Session.GetString(SessionKeys.Rol);
    var haySesion = !string.IsNullOrWhiteSpace(Context.Session.GetString(SessionKeys.UsuarioId));
    var esAdmin = string.Equals(rolSesion, "Admin", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/gestion_bibliotecaria.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

<header>
    <nav class="navbar navbar-expand-sm">
        <div class="container">

            <!-- LOGO -->
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="~/assets/images/whiiteLogoR.png"
                     height="60"
                     width="100"
                     class="me-2">
            </a>

            <!-- BOTON MOBILE -->
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target=".navbar-collapse">
                <img src="~/assets/icons/menu_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                     width="24">
            </button>

            <!-- MENU -->
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                <ul class="navbar-nav flex-grow-1">

                    <!-- HOME -->
                    <li class="nav-item">
                        <a class="nav-link nav-btn d-flex align-items-center gap-2" href="/">
                            <img src="~/assets/icons/home_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="20">
                            Home
                        </a>
                    </li>

                    <!-- BIBLIOTECA -->
                    <li class="nav-item dropdown">
                        <a class="nav-link nav-btn dropdown-toggle d-flex align-items-center gap-2"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            <img src="~/assets/icons/inventory_2_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="20">
                            Biblioteca
                        </a>

                        <ul class="dropdown-menu custom-dropdown-menu">
                            <li><a class="dropdown-item custom-dropdown-item" href="/Libro">Libros</a></li>
                            <li><a class="dropdown-item custom-dropdown-item" href="/Autor">Autores</a></li>
                            <li><a class="dropdown-item custom-dropdown-item" href="/Ejemplar">Ejemplares</a></li>
                            <li><a class="dropdown-item custom-dropdown-item" href="#">Categorías</a></li>
                            <li><a class="dropdown-item custom-dropdown-item" href="#">Editoriales</a></li>
                        </ul>
                    </li>

                    <!-- CIRCULACION -->
                    <li class="nav-item dropdown">
                        <a class="nav-link nav-btn dropdown-toggle d-flex align-items-center gap-2"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            <img src="~/assets/icons/sync_alt_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="20">
                            Circulación
                        </a>

                        <ul class="dropdown-menu custom-dropdown-menu">
                            <li><a class="dropdown-item custom-dropdown-item" href="#">Préstamos</a></li>
                            <li><a class="dropdown-item custom-dropdown-item" href="#">Devoluciones</a></li>
                            <li><a class="dropdown-item custom-dropdown-item" href="#">Reservas</a></li>
                            <li><a class="dropdown-item custom-dropdown-item" href="#">Historial</a></li>
                            <li><a class="dropdown-item custom-dropdown-item" href="#">Multas</a></li>
                        </ul>
                    </li>

                    @if (esAdmin)
                    {
                        <li class="nav-item">
                            <a class="nav-link nav-btn d-flex align-items-center gap-2" href="/Usuarios">
                                <img src="~/assets/icons/group_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="20">
                                Usuarios
                            </a>
                        </li>
                    }

                    <!-- REPORTES -->
                    <li class="nav-item dropdown">
                        <a class="nav-link nav-btn dropdown-toggle d-flex align-items-center gap-2"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            <img src="~/assets/icons/bar_chart_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="20">
                            Reportes
                        </a>

                        <ul class="dropdown-menu custom-dropdown-menu">
                            <li><a class="dropdown-item custom-dropdown-item" href="#">Préstamos realizados</a></li>
                            <li><a class="dropdown-item custom-dropdown-item" href="#">Libros más prestados</a></li>
                            <li><a class="dropdown-item custom-dropdown-item" href="#">Ejemplares disponibles</a></li>
                            <li><a class="dropdown-item custom-dropdown-item" href="#">Usuarios con retraso</a></li>
                        </ul>
                    </li>
                </ul>

                <!-- DERECHA -->
                <ul class="navbar-nav">
                    @if (!haySesion)
                    {
                        <li class="nav-item">
                            <a class="nav-link nav-btn d-flex align-items-center gap-2" href="/Login">
                                <img src="~/assets/icons/person_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="20">
                                Iniciar sesion
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link nav-btn dropdown-toggle d-flex align-items-center gap-2"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                <img src="~/assets/icons/person_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="20">
                                @nombreUsuarioSesion
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end custom-dropdown-menu">
                                <li>
                                    <form method="post" asp-page="/Login" asp-page-handler="Logout">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item custom-dropdown-item">Cerrar sesion</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }

                    @* <li class="nav-item">
                        <a class="nav-link nav-btn d-flex align-items-center gap-2" href="#">
                            <img src="~/assets/icons/account_box_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="20">
                            Registrarse
                        </a>
                    </li> *@
                </ul>

            </div>
        </div>
    </nav>
</header>


<!-- CONTENIDO PRINCIPAL -->

<main class="container-fluid main-content">

    @RenderBody()

</main>


<!-- FOOTER -->

<footer class="footer-custom">

    <div class="container footer-content">

        <div class="footer-left">
            <img src="~/assets/images/whiiteLogoR.png"
                    height="60"
                    width="100">
        </div>

        <div class="footer-center">
            © 2026 StarBook Library
        </div>

        <div class="footer-right">
            <a href="/Privacy">Privacy</a>
        </div>

    </div>

</footer>


<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
