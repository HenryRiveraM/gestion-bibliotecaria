@page "{id:int}"
@model gestion_bibliotecaria.Pages.InventarioDeleteModel
@{
    ViewData["Title"] = "Eliminar Ejemplar - Inventario";
}

<h1>Eliminar Ejemplar del Inventario</h1>

<div class="alert alert-warning">
    <h4>¿Estás seguro de que deseas eliminar este ejemplar del inventario?</h4>
    <p>Esta acción no se puede deshacer.</p>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID Ejemplar</dt>
            <dd class="col-sm-9">@Model.Ejemplar.EjemplarId</dd>

            <dt class="col-sm-3">Código de Inventario</dt>
            <dd class="col-sm-9"><strong>@Model.Ejemplar.CodigoInventario</strong></dd>

            <dt class="col-sm-3">Libro</dt>
            <dd class="col-sm-9">@Model.TituloLibro</dd>

            <dt class="col-sm-3">Estado de Conservación</dt>
            <dd class="col-sm-9">@(Model.Ejemplar.EstadoConservacion ?? "N/A")</dd>

            <dt class="col-sm-3">Ubicación</dt>
            <dd class="col-sm-9">@(Model.Ejemplar.Ubicacion ?? "N/A")</dd>

            <dt class="col-sm-3">Disponible</dt>
            <dd class="col-sm-9">
                @if (Model.Ejemplar.Disponible)
                {
                    <span class="badge bg-success">Sí</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">No</span>
                }
            </dd>

            <dt class="col-sm-3">Dado de Baja</dt>
            <dd class="col-sm-9">
                @if (Model.Ejemplar.DadoDeBaja)
                {
                    <span class="badge bg-danger">Sí</span>
                    @if (!string.IsNullOrEmpty(Model.Ejemplar.MotivoBaja))
                    {
                        <br/><small>Motivo: @Model.Ejemplar.MotivoBaja</small>
                    }
                }
                else
                {
                    <span class="badge bg-secondary">No</span>
                }
            </dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">@(Model.Ejemplar.Estado ? "Activo" : "Inactivo")</dd>

            <dt class="col-sm-3">Fecha de Registro</dt>
            <dd class="col-sm-9">@Model.Ejemplar.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</dd>

            @if (Model.Ejemplar.UltimaActualizacion.HasValue)
            {
                <dt class="col-sm-3">Última Actualización</dt>
                <dd class="col-sm-9">@Model.Ejemplar.UltimaActualizacion.Value.ToString("dd/MM/yyyy HH:mm")</dd>
            }
        </dl>
    </div>
</div>

<form method="post" class="mt-3">
    <button type="submit" class="btn btn-danger">Eliminar del Inventario</button>
    <a asp-page="Inventario" class="btn btn-secondary">Cancelar</a>
</form>
