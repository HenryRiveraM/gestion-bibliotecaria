@page "{id:int}"
@model gestion_bibliotecaria.Pages.LibroDeleteModel
@{
    ViewData["Title"] = "Eliminar Libro";
}

<h1>Eliminar Libro</h1>

<div class="alert alert-warning">
    <h4>¿Estás seguro de que deseas eliminar este libro?</h4>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.Libro.LibroId</dd>

            <dt class="col-sm-3">Título</dt>
            <dd class="col-sm-9">@Model.Libro.Titulo</dd>

            <dt class="col-sm-3">Editorial</dt>
            <dd class="col-sm-9">@Model.Libro.Editorial</dd>

            <dt class="col-sm-3">Edición</dt>
            <dd class="col-sm-9">@Model.Libro.Edicion</dd>

            <dt class="col-sm-3">Año de Publicación</dt>
            <dd class="col-sm-9">@Model.Libro.AñoPublicacion</dd>

            <dt class="col-sm-3">Descripción</dt>
            <dd class="col-sm-9">@Model.Libro.Descripcion</dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">@(Model.Libro.Estado ? "Activo" : "Inactivo")</dd>

            <dt class="col-sm-3">Fecha de Registro</dt>
            <dd class="col-sm-9">@Model.Libro.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</dd>
        </dl>
    </div>
</div>

<form method="post" class="mt-3">
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-page="Libro" class="btn btn-secondary">Cancelar</a>
</form>
