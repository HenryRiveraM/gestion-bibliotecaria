@page
@model gestion_bibliotecaria.Pages.LibroModel
@{
    ViewData["Title"] = "Gestión de Libros - Inventario";
}

<h1>📚 Gestión de Libros (Inventario)</h1>

<div class="mb-3">
    <a asp-page="LibroCreate" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Agregar Nuevo Libro
    </a>
</div>

@if (Model.Libros.Count == 0)
{
    <div class="alert alert-info">
        No hay libros registrados en el inventario.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Título</th>
                    <th>Editorial</th>
                    <th>Edición</th>
                    <th>Año</th>
                    <th>Estado</th>
                    <th>Fecha Registro</th>
                    <th style="width: 200px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var libro in Model.Libros)
                {
                    <tr>
                        <td>@libro.LibroId</td>
                        <td><strong>@libro.Titulo</strong></td>
                        <td>@(libro.Editorial ?? "N/A")</td>
                        <td>@(libro.Edicion ?? "N/A")</td>
                        <td>@(libro.AñoPublicacion?.ToString() ?? "N/A")</td>
                        <td>
                            @if (libro.Estado)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </td>
                        <td>@libro.FechaRegistro.ToString("dd/MM/yyyy")</td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-page="LibroEdit" asp-route-id="@libro.LibroId" 
                                   class="btn btn-sm btn-warning" title="Editar">
                                    ✏️
                                </a>
                                <a asp-page="LibroDelete" asp-route-id="@libro.LibroId" 
                                   class="btn btn-sm btn-danger" title="Eliminar">
                                    🗑️
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="alert alert-secondary mt-3">
        <strong>Total de libros en inventario:</strong> @Model.Libros.Count
    </div>
}
