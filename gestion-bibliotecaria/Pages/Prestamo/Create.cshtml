@page "/Prestamo/Create"
@using System.Linq
@model gestion_bibliotecaria.Pages.Prestamo.PrestamoModel
@{
    ViewData["Title"] = "Nuevo Préstamo";
    var reabrirModalLector = ViewData.ModelState.Keys.Any(k => k.StartsWith("NuevoLector.", StringComparison.Ordinal));
    var fechaMinimaDevolucion = Model.FechaPrestamoDisplay.Date.AddDays(1).ToString("yyyy-MM-dd");
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/prestamo.css" />
}

<div class="prestamo-page">
    <div class="prestamo-shell">
        <div class="page-header">
            <div class="titulo-logo">
                <div class="page-icon-shell">
                    <img src="~/assets/icons/sync_alt_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-header" alt="Préstamos" />
                </div>
                <div>
                    <h1>Registrar préstamo</h1>
                    <p class="page-subtitle">Selecciona lector, ejemplares y fecha de devolución sin alterar la lógica del sistema.</p>
                </div>
            </div>

            <a class="btn-ghost-action" href="/Prestamo">
                <img src="~/assets/icons/library_books_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-btn" alt="Ver préstamos" />
                Ver préstamos realizados
            </a>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.MensajeOk))
        {
            <div class="alert-custom alert-success-custom" id="servidor-ok">
                @Model.MensajeOk
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.MensajeError))
        {
            <div class="alert-custom alert-danger-custom" id="servidor-error">
                @Model.MensajeError
            </div>
        }

        <div id="prestamoFeedback" class="alert-custom alert-danger-custom" style="display:none;"></div>

        <form method="post" asp-page-handler="Crear" id="formPrestamo" class="prestamo-form" novalidate>
            @Html.AntiForgeryToken()

            <section class="prestamo-panel prestamo-panel-compact">
                <div class="panel-heading">
                    <div>
                        <span class="form-section-title">Paso 1</span>
                        <h2>Plazos del préstamo</h2>
                    </div>
                </div>

                <div class="prestamo-grid prestamo-grid-tight">
                    <div class="field-block">
                        <label class="field-label">Fecha de préstamo</label>
                        <div class="dato-estatico">
                            @Model.FechaPrestamoDisplay.ToString("dd/MM/yyyy")
                        </div>
                        <small class="field-help">Se toma automáticamente con la fecha actual del sistema.</small>
                    </div>

                    <div class="field-block">
                        <label for="FechaDevolucionEsperada" class="field-label">Fecha de devolución esperada</label>
                        <input type="date"
                               id="FechaDevolucionEsperada"
                               name="FechaDevolucionEsperada"
                               class="input-form"
                               min="@fechaMinimaDevolucion"
                               value="@Model.FechaDevolucionDefault.ToString("yyyy-MM-dd")" />
                        <small class="field-help">Debe ser posterior a la fecha del préstamo para coincidir con la validación del servidor.</small>
                        <div id="error-FechaDevolucionEsperada" class="field-error"></div>
                    </div>
                </div>
            </section>

            <section class="prestamo-panel prestamo-panel-compact">
                <div class="panel-heading">
                    <div>
                        <span class="form-section-title">Paso 2</span>
                        <h2>Información del lector</h2>
                    </div>
                    <button type="button" class="btn-nuevo" data-bs-toggle="modal" data-bs-target="#modalNuevoLector">
                        <img src="~/assets/icons/add_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-btn" alt="Nuevo lector" />
                        Nuevo lector
                    </button>
                </div>

                <p class="panel-copy">Busca por CI y, si hace falta, registra al lector sin salir de esta pantalla.</p>

                <div class="lector-layout">
                    <div class="lector-form-column">
                        <div class="prestamo-grid lector-grid">
                            <div class="field-block field-block-wide">
                                <label for="LectorCi" class="field-label">Documento de identidad</label>
                                <div class="field-with-floating-results">
                                    <input type="text"
                                           id="LectorCi"
                                           name="LectorCi"
                                           class="input-form"
                                           placeholder="Escribe el CI para buscar al lector"
                                           oninput="buscarLectores(this.value)"
                                           autocomplete="off" />
                                    <div id="sugerencias-lectores" class="sugerencias"></div>
                                </div>
                                <small class="field-help">Al seleccionar una sugerencia se cargará el lector automáticamente.</small>
                                <div id="error-LectorCi" class="field-error"></div>
                            </div>

                            <div class="field-block">
                                <label for="LectorComp" class="field-label">Complemento</label>
                                <input type="text"
                                       id="LectorComp"
                                       name="LectorComp"
                                       class="input-form"
                                       maxlength="8"
                                       placeholder="Ej: 1P" />
                                <small class="field-help">Opcional. Si existe, úsalo para una búsqueda exacta.</small>
                            </div>
                        </div>

                        <input type="hidden" id="LectorId" name="LectorId" />
                        <div id="error-LectorId" class="field-error"></div>
                    </div>

                    <div class="lector-summary-column">
                        <div id="lector-info" class="selected-lector-card selected-lector-card-side" style="display:none;">
                            <span class="selected-lector-label">Lector seleccionado</span>
                            <strong id="lector-nombre"></strong>
                            <small id="lector-ci-display"></small>
                        </div>
                    </div>
                </div>
            </section>

            <section class="prestamo-panel">
                <div class="panel-heading">
                    <div>
                        <span class="form-section-title">Paso 3</span>
                        <h2>Ejemplares a prestar</h2>
                    </div>
                </div>

                <p class="panel-copy">Añade hasta tres ejemplares. Cada uno puede llevar una observación de salida.</p>

                <div class="ejemplares-layout">
                    <div class="ejemplares-selector-column">
                        <div class="selector-toolbar selector-toolbar-vertical">
                            <div class="custom-select-wrapper">
                                <div class="custom-select" id="custom-select-ejemplar">
                                    <div class="select-trigger">
                                        <input type="text"
                                               id="input-busqueda-ejemplar"
                                               class="search-inside-select"
                                               placeholder="Busca por título o código de inventario"
                                               autocomplete="off"
                                               onfocus="mostrarDropdown()" />
                                        <svg class="select-arrow" viewBox="0 0 24 24" aria-hidden="true">
                                            <polyline points="6 9 12 15 18 9"></polyline>
                                        </svg>
                                    </div>
                                    <div class="select-dropdown">
                                        <div class="select-options" id="lista-opciones-ejemplares">
                                            <div class="option-loading">Cargando ejemplares...</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <button type="button" class="btn-nuevo btn-full-width" onclick="confirmarSeleccionEjemplar()">
                                <img src="~/assets/icons/add_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-btn" alt="Añadir ejemplar" />
                                Añadir ejemplar
                            </button>
                        </div>

                        <div id="error-EjemplarData" class="field-error field-error-block"></div>
                    </div>

                    <div class="ejemplares-summary-column">
                        <div class="tabla-container tabla-prestamo-seleccion">
                            <div id="prestamo-empty-state" class="empty-selection-state">
                                <strong>Aún no agregaste ejemplares</strong>
                                <span>Busca un ejemplar y presiónalo en “Añadir ejemplar” para incorporarlo al préstamo.</span>
                            </div>

                            <table id="tabla-ejemplares" class="tabla-ejemplar">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Ejemplar</th>
                                        <th>Conservación</th>
                                        <th>Observaciones de salida</th>
                                        <th>Acción</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <input type="hidden" id="EjemplarData" name="EjemplarData" value="[]" />
                <input type="hidden" id="ejemplar-temp-id" />
                <input type="hidden" id="ejemplar-temp-texto" />
            </section>

            <div class="form-actions">
                <a class="btn-secondary text-decoration-none" href="/Prestamo">Cancelar</a>
                <button type="submit" class="btn-nuevo">
                    <img src="~/assets/icons/add_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-btn" alt="Registrar préstamo" />
                    Finalizar préstamo
                </button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="modalNuevoLector" tabindex="-1" aria-labelledby="modalNuevoLectorLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-theme">
            <div class="modal-header modal-header-theme">
                <div>
                    <h5 class="modal-title" id="modalNuevoLectorLabel">Nuevo lector</h5>
                    <p class="modal-subtitle">Completa los datos mínimos para registrar un lector desde préstamos.</p>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form method="post" asp-page-handler="CrearLector" id="formNuevoLector" novalidate>
                @Html.AntiForgeryToken()

                <div class="modal-body">
                    <div id="lectorModalFeedback" class="text-error-summary" style="display:none;"></div>

                    <div class="prestamo-grid lector-modal-grid">
                        <div class="field-block">
                            <label asp-for="NuevoLector.CI" class="field-label">CI</label>
                            <input type="text" asp-for="NuevoLector.CI" class="input-form" id="NuevoLector_CI" />
                            <div id="error-NuevoLector_CI" class="field-error"></div>
                        </div>

                        <div class="field-block">
                            <label asp-for="NuevoLector.Complemento" class="field-label">Complemento</label>
                            <input type="text" asp-for="NuevoLector.Complemento" class="input-form" id="NuevoLector_Complemento" />
                        </div>
                    </div>

                    <div class="field-block">
                        <label asp-for="NuevoLector.Nombres" class="field-label">Nombres</label>
                        <input type="text" asp-for="NuevoLector.Nombres" class="input-form" id="NuevoLector_Nombres" />
                        <div id="error-NuevoLector_Nombres" class="field-error"></div>
                    </div>

                    <div class="prestamo-grid lector-modal-grid">
                        <div class="field-block">
                            <label asp-for="NuevoLector.PrimerApellido" class="field-label">Primer apellido</label>
                            <input type="text" asp-for="NuevoLector.PrimerApellido" class="input-form" id="NuevoLector_PrimerApellido" />
                            <div id="error-NuevoLector_PrimerApellido" class="field-error"></div>
                        </div>

                        <div class="field-block">
                            <label asp-for="NuevoLector.SegundoApellido" class="field-label">Segundo apellido</label>
                            <input type="text" asp-for="NuevoLector.SegundoApellido" class="input-form" id="NuevoLector_SegundoApellido" />
                        </div>
                    </div>

                    <div class="field-block">
                        <label asp-for="NuevoLector.Email" class="field-label">Correo electrónico</label>
                        <input type="email" asp-for="NuevoLector.Email" class="input-form" id="NuevoLector_Email" />
                        <div id="error-NuevoLector_Email" class="field-error"></div>
                    </div>
                </div>

                <div class="modal-footer modal-footer-theme">
                    <button type="button" class="btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn-nuevo">Guardar lector</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let ejemplaresSeleccionados = [];
        let catalogoEjemplares = [];

        const reabrirModalLector = @reabrirModalLector.ToString().ToLowerInvariant();

        function obtenerBasePrestamo() {
            return window.location.pathname.replace(/\/Create$/, '') || window.location.pathname;
        }

        function obtenerFeedbackBox() {
            return document.getElementById('prestamoFeedback');
        }

        function mostrarFeedback(mensaje) {
            const box = obtenerFeedbackBox();
            if (!box) return;

            box.textContent = mensaje;
            box.style.display = 'block';
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function limpiarFeedback() {
            const box = obtenerFeedbackBox();
            if (!box) return;

            box.style.display = 'none';
            box.textContent = '';
        }

        function setFieldError(id, mensaje) {
            const field = document.getElementById(id);
            if (field) {
                field.textContent = mensaje;
            }
        }

        function clearFieldError(id) {
            setFieldError(id, '');
        }

        function limpiarErroresFormulario() {
            ['error-LectorCi', 'error-LectorId', 'error-EjemplarData', 'error-FechaDevolucionEsperada'].forEach(clearFieldError);
            limpiarFeedback();
        }

        function mostrarMensajeError(mensaje, errorId) {
            if (errorId) {
                setFieldError(errorId, mensaje);
            }
            mostrarFeedback(mensaje);
        }

        function limpiarLectorSeleccionado() {
            document.getElementById('LectorId').value = '';
            document.getElementById('lector-nombre').textContent = '';
            document.getElementById('lector-ci-display').textContent = '';
            document.getElementById('lector-info').style.display = 'none';
        }

        async function buscarLectores(q) {
            clearFieldError('error-LectorCi');
            clearFieldError('error-LectorId');

            if (!q || q.trim().length < 1) {
                document.getElementById('sugerencias-lectores').innerHTML = '';
                limpiarLectorSeleccionado();
                return;
            }

            const base = obtenerBasePrestamo();
            const res = await fetch(`${base}?handler=AutocompleteLectores&q=${encodeURIComponent(q.trim())}`);
            const data = await res.json();
            renderSugerenciasLectores(data);
        }

        function renderSugerenciasLectores(items) {
            const cont = document.getElementById('sugerencias-lectores');
            cont.innerHTML = '';

            if (!items.length) {
                cont.innerHTML = '<div class="sugerencia-empty">No se encontraron lectores</div>';
                return;
            }

            items.forEach(item => {
                const div = document.createElement('button');
                div.type = 'button';
                div.className = 'sugerencia-item';
                div.textContent = item.label;
                div.onclick = () => seleccionarLector(item.label);
                cont.appendChild(div);
            });
        }

        async function seleccionarLector(valorSugerencia) {
            const cont = document.getElementById('sugerencias-lectores');
            const fullCi = (valorSugerencia || '').trim();
            let ciValue = fullCi;
            let compValue = '';

            const parts = fullCi.split('-');
            if (parts.length > 1) {
                ciValue = parts[0].trim();
                compValue = parts.slice(1).join('-').trim();
            }

            document.getElementById('LectorCi').value = ciValue;
            document.getElementById('LectorComp').value = compValue;
            cont.innerHTML = '';

            const base = obtenerBasePrestamo();
            const params = new URLSearchParams();
            params.append('handler', 'BuscarLectorPorCi');
            params.append('ci', ciValue);
            if (compValue) {
                params.append('complemento', compValue);
            }

            try {
                const res = await fetch(`${base}?${params.toString()}`);
                const data = await res.json();

                if (!data.success) {
                    limpiarLectorSeleccionado();
                    mostrarMensajeError(data.message || 'No se encontró el lector.', 'error-LectorId');
                    return;
                }

                document.getElementById('LectorId').value = data.id;
                document.getElementById('lector-nombre').textContent = data.nombreCompleto;
                document.getElementById('lector-ci-display').textContent = compValue ? `${ciValue}-${compValue}` : ciValue;
                document.getElementById('lector-info').style.display = 'grid';
                clearFieldError('error-LectorId');
                limpiarFeedback();
            } catch (error) {
                limpiarLectorSeleccionado();
                mostrarMensajeError('Error al buscar el lector: ' + error.message, 'error-LectorId');
            }
        }

        function normalizar(texto) {
            return (texto || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim();
        }

        function mostrarDropdown() {
            const ejemplaresIds = new Set(ejemplaresSeleccionados.map(x => String(x.id)));
            const filtrados = catalogoEjemplares.filter(item => !ejemplaresIds.has(String(item.id)));
            renderizarOpcionesEjemplares(filtrados);
            document.getElementById('custom-select-ejemplar').classList.add('active');
        }

        function renderizarOpcionesEjemplares(items) {
            const contenedor = document.getElementById('lista-opciones-ejemplares');
            contenedor.innerHTML = '';

            if (!items.length) {
                contenedor.innerHTML = '<div class="option-loading">No hay ejemplares disponibles con ese criterio.</div>';
                return;
            }

            items.forEach(item => {
                const div = document.createElement('button');
                div.type = 'button';
                div.className = 'option';
                div.textContent = item.label;
                div.onclick = () => {
                    document.getElementById('input-busqueda-ejemplar').value = item.label;
                    document.getElementById('ejemplar-temp-id').value = item.id;
                    document.getElementById('ejemplar-temp-texto').value = item.label;
                    document.getElementById('custom-select-ejemplar').classList.remove('active');
                    clearFieldError('error-EjemplarData');
                };
                contenedor.appendChild(div);
            });
        }

        async function confirmarSeleccionEjemplar() {
            const id = document.getElementById('ejemplar-temp-id').value;
            const texto = document.getElementById('ejemplar-temp-texto').value;

            if (!id) {
                mostrarMensajeError('Selecciona un ejemplar antes de añadirlo.', 'error-EjemplarData');
                return;
            }

            if (ejemplaresSeleccionados.some(e => String(e.id) === String(id))) {
                mostrarMensajeError('Este ejemplar ya fue agregado al préstamo.', 'error-EjemplarData');
                return;
            }

            if (ejemplaresSeleccionados.length >= 3) {
                mostrarMensajeError('No se pueden prestar más de 3 ejemplares a la vez.', 'error-EjemplarData');
                return;
            }

            const base = obtenerBasePrestamo();
            const res = await fetch(`${base}?handler=EjemplarDetalle&id=${id}`);
            const detalle = await res.json();

            ejemplaresSeleccionados.push({
                id: id,
                label: texto,
                estadoConservacion: detalle?.estadoConservacion || 'Sin dato',
                observaciones: ''
            });

            renderTablaEjemplares();
            document.getElementById('input-busqueda-ejemplar').value = '';
            document.getElementById('ejemplar-temp-id').value = '';
            document.getElementById('ejemplar-temp-texto').value = '';
            clearFieldError('error-EjemplarData');
            limpiarFeedback();
        }

        function renderTablaEjemplares() {
            const tbody = document.querySelector('#tabla-ejemplares tbody');
            const emptyState = document.getElementById('prestamo-empty-state');
            tbody.innerHTML = '';

            if (!ejemplaresSeleccionados.length) {
                emptyState.style.display = 'grid';
            } else {
                emptyState.style.display = 'none';
            }

            ejemplaresSeleccionados.forEach((ejemplar, idx) => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><span class="badge badge-dark">#${ejemplar.id}</span></td>
                    <td>
                        <strong>${ejemplar.label}</strong>
                    </td>
                    <td><span class="estado activo">${ejemplar.estadoConservacion}</span></td>
                    <td>
                        <input
                            type="text"
                            class="input-form tabla-input"
                            value="${(ejemplar.observaciones || '').replace(/"/g, '&quot;')}"
                            placeholder="Detalle opcional del estado de salida"
                            oninput="updateObs(${idx}, this.value)" />
                    </td>
                    <td>
                        <button type="button" class="btn-remove-chip" onclick="quitarEjemplar(${idx})">Quitar</button>
                    </td>`;
                tbody.appendChild(tr);
            });

            document.getElementById('EjemplarData').value = JSON.stringify(
                ejemplaresSeleccionados.map(x => ({
                    id: parseInt(x.id, 10),
                    observaciones: x.observaciones || ''
                }))
            );
        }

        function updateObs(idx, valor) {
            ejemplaresSeleccionados[idx].observaciones = valor;
            document.getElementById('EjemplarData').value = JSON.stringify(
                ejemplaresSeleccionados.map(x => ({
                    id: parseInt(x.id, 10),
                    observaciones: x.observaciones || ''
                }))
            );
        }

        function quitarEjemplar(idx) {
            ejemplaresSeleccionados.splice(idx, 1);
            renderTablaEjemplares();
        }

        function validarPrestamoFrontend() {
            limpiarErroresFormulario();
            let valido = true;

            const lectorId = document.getElementById('LectorId').value.trim();
            const lectorCi = document.getElementById('LectorCi').value.trim();
            const fechaDevolucion = document.getElementById('FechaDevolucionEsperada').value;

            if (!lectorCi) {
                mostrarMensajeError('Debes ingresar el CI del lector.', 'error-LectorCi');
                valido = false;
            }

            if (!lectorId) {
                mostrarMensajeError('Selecciona un lector válido desde las sugerencias.', 'error-LectorId');
                valido = false;
            }

            if (!ejemplaresSeleccionados.length) {
                mostrarMensajeError('Debes seleccionar al menos un ejemplar.', 'error-EjemplarData');
                valido = false;
            }

            if (ejemplaresSeleccionados.length > 3) {
                mostrarMensajeError('No se pueden prestar más de 3 ejemplares a la vez.', 'error-EjemplarData');
                valido = false;
            }

            if (!fechaDevolucion) {
                mostrarMensajeError('Debes indicar la fecha de devolución esperada.', 'error-FechaDevolucionEsperada');
                valido = false;
            } else {
                const seleccionada = new Date(fechaDevolucion + 'T00:00:00');
                const fechaMinima = new Date('@fechaMinimaDevolucion' + 'T00:00:00');
                if (seleccionada < fechaMinima) {
                    mostrarMensajeError('La fecha de devolución debe ser posterior a la fecha del préstamo.', 'error-FechaDevolucionEsperada');
                    valido = false;
                }
            }

            return valido;
        }

        function validarNuevoLectorFrontend() {
            const feedback = document.getElementById('lectorModalFeedback');
            const errores = [];

            ['error-NuevoLector_CI', 'error-NuevoLector_Nombres', 'error-NuevoLector_PrimerApellido', 'error-NuevoLector_Email'].forEach(clearFieldError);
            feedback.style.display = 'none';
            feedback.textContent = '';

            const ci = document.getElementById('NuevoLector_CI').value.trim();
            const nombres = document.getElementById('NuevoLector_Nombres').value.trim();
            const primerApellido = document.getElementById('NuevoLector_PrimerApellido').value.trim();
            const email = document.getElementById('NuevoLector_Email').value.trim();

            if (!ci) {
                errores.push('El CI es obligatorio.');
                setFieldError('error-NuevoLector_CI', 'El CI es obligatorio.');
            }

            if (!nombres) {
                errores.push('Los nombres son obligatorios.');
                setFieldError('error-NuevoLector_Nombres', 'Los nombres son obligatorios.');
            }

            if (!primerApellido) {
                errores.push('El primer apellido es obligatorio.');
                setFieldError('error-NuevoLector_PrimerApellido', 'El primer apellido es obligatorio.');
            }

            if (!email) {
                errores.push('El correo electrónico es obligatorio.');
                setFieldError('error-NuevoLector_Email', 'El correo electrónico es obligatorio.');
            } else {
                const emailValido = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);
                if (!emailValido) {
                    errores.push('Introduce un correo electrónico válido.');
                    setFieldError('error-NuevoLector_Email', 'Introduce un correo electrónico válido.');
                }
            }

            if (errores.length) {
                feedback.textContent = errores[0];
                feedback.style.display = 'block';
                return false;
            }

            return true;
        }

        document.addEventListener('DOMContentLoaded', async () => {
            renderTablaEjemplares();

            const base = obtenerBasePrestamo();
            const res = await fetch(`${base}?handler=AutocompleteEjemplares&q=`);
            catalogoEjemplares = await res.json();
            renderizarOpcionesEjemplares(catalogoEjemplares);

            document.getElementById('LectorCi').addEventListener('input', () => {
                limpiarLectorSeleccionado();
                limpiarFeedback();
            });

            document.getElementById('LectorComp').addEventListener('input', () => {
                limpiarLectorSeleccionado();
                limpiarFeedback();
            });

            document.getElementById('input-busqueda-ejemplar').addEventListener('input', function (e) {
                const termino = normalizar(e.target.value);
                // Filtrar ejemplares NO seleccionados
                const ejemplaresIds = new Set(ejemplaresSeleccionados.map(x => String(x.id)));
                const filtrados = catalogoEjemplares.filter(item => 
                    normalizar(item.label).includes(termino) && !ejemplaresIds.has(String(item.id))
                );
                renderizarOpcionesEjemplares(filtrados);
                mostrarDropdown();
            });

            document.getElementById('FechaDevolucionEsperada').addEventListener('input', () => {
                clearFieldError('error-FechaDevolucionEsperada');
            });

            document.getElementById('formPrestamo').addEventListener('submit', (e) => {
                if (!validarPrestamoFrontend()) {
                    e.preventDefault();
                    return false;
                }

                document.getElementById('EjemplarData').value = JSON.stringify(
                    ejemplaresSeleccionados.map(x => ({
                        id: parseInt(x.id, 10),
                        observaciones: x.observaciones || ''
                    }))
                );
            });

            document.getElementById('formNuevoLector').addEventListener('submit', (e) => {
                if (!validarNuevoLectorFrontend()) {
                    e.preventDefault();
                }
            });

            document.addEventListener('click', (e) => {
                const select = document.getElementById('custom-select-ejemplar');
                if (select && !select.contains(e.target)) {
                    select.classList.remove('active');
                }

                const sugerencias = document.getElementById('sugerencias-lectores');
                const lectorContainer = document.querySelector('.field-with-floating-results');
                if (sugerencias && lectorContainer && !lectorContainer.contains(e.target)) {
                    sugerencias.innerHTML = '';
                }
            });

            if (reabrirModalLector) {
                const modalElement = document.getElementById('modalNuevoLector');
                if (modalElement && window.bootstrap?.Modal) {
                    window.bootstrap.Modal.getOrCreateInstance(modalElement).show();
                }
            }
        });
    </script>
}
