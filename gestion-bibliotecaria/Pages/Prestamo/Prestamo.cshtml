@page "/Prestamo"
@using System.Linq
@model gestion_bibliotecaria.Pages.Prestamo.PrestamoModel
@{
    ViewData["Title"] = "Préstamos realizados";

    var totalPrestamos = Model.PrestamosDetallados.Count;
    var prestamosActivos = Model.PrestamosDetallados.Count(p => !p.FechaDevolucionReal.HasValue && p.Estado == 1);
    var prestamosDevueltos = Model.PrestamosDetallados.Count(p => p.FechaDevolucionReal.HasValue);
    var prestamosAnulados = Model.PrestamosDetallados.Count(p => p.Estado == 0);
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/prestamo.css" />
}

<div class="prestamo-page">
    <div class="prestamo-shell">
        <div class="page-header">
            <div class="titulo-logo">
                <div class="page-icon-shell">
                    <img src="~/assets/icons/library_books_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-header" alt="Préstamos realizados" />
                </div>
                <div>
                    <h1>Préstamos realizados</h1>
                    <p class="page-subtitle">Consulta el historial, busca por lector o ejemplar y revisa los detalles de cada operación.</p>
                </div>
            </div>

            <a class="btn-nuevo" href="/Prestamo/Create">
                <img src="~/assets/icons/add_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-btn" alt="Nuevo préstamo" />
                Nuevo préstamo
            </a>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.MensajeOk))
        {
            <div class="alert-custom alert-success-custom">@Model.MensajeOk</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.MensajeError))
        {
            <div class="alert-custom alert-danger-custom">@Model.MensajeError</div>
        }

        <div class="filtros-barra">
            <div class="filtro-item filtro-buscar">
                <input id="buscador-prestamo"
                       type="text"
                       class="input-filtro"
                       placeholder="Buscar por lector, libro, código o estado..."
                       autocomplete="off" />
            </div>
        </div>

        <form id="prestamoAntiForgeryForm" method="post" class="prestamo-hidden-token">
            @Html.AntiForgeryToken()
        </form>

        @if (!Model.PrestamosDetallados.Any())
        {
            <div class="tabla-container empty-table-state">
                <strong>No hay préstamos registrados en el sistema.</strong>
                <span>Cuando registres uno, aparecerá aquí con su estado, lector y fechas clave.</span>
            </div>
        }
        else
        {
            <div class="tabla-container">
                <table class="tabla-ejemplar tabla-prestamos-historial">
                    <thead>
                        <tr>
                            <th>Libro</th>
                            <th>Código</th>
                            <th>Lector</th>
                            <th>Estado</th>
                            <th>Salida</th>
                            <th>Esperada</th>
                            <th>Devolución real</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="tabla-prestamos-body">
                        @foreach (var p in Model.PrestamosDetallados)
                        {
                            var estadoTexto = p.Estado == 0
                                ? "Anulado"
                                : p.FechaDevolucionReal.HasValue
                                    ? "Devuelto"
                                    : "Activo";

                            var estadoClase = p.Estado == 0
                                ? "estado-danger"
                                : p.FechaDevolucionReal.HasValue
                                    ? "estado-info"
                                    : "activo";

                            <tr class="prestamo-row"
                                data-lector="@p.NombreLector.ToLowerInvariant()"
                                data-libro="@p.TituloLibro.ToLowerInvariant()"
                                data-codigo="@p.CodigoInventario.ToLowerInvariant()"
                                data-estado="@estadoTexto.ToLowerInvariant()">
                                <td>
                                    <strong>@p.TituloLibro</strong>
                                </td>
                                <td><span class="badge badge-outline">@p.CodigoInventario</span></td>
                                <td>@p.NombreLector.ToDisplayName()</td>
                                <td><span class="estado @estadoClase">@estadoTexto</span></td>
                                <td>@p.FechaPrestamo.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@p.FechaDevolucionEsperada.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (p.FechaDevolucionReal.HasValue)
                                    {
                                        @p.FechaDevolucionReal.Value.ToString("dd/MM/yyyy HH:mm")
                                    }
                                    else
                                    {
                                        <span class="text-pendiente">Pendiente</span>
                                    }
                                </td>
                                <td class="td-acciones">
                                    <button type="button"
                                            class="btn-accion btn-detalles"
                                            onclick="mostrarDetalles(@p.PrestamoId)"
                                            title="Ver detalles">
                                        <img src="~/assets/icons/visibility_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="18" alt="Ver detalles" />
                                    </button>

                                    @if (p.Estado == 1 && !p.FechaDevolucionReal.HasValue)
                                    {
                                        <button type="button"
                                                class="btn-accion btn-anular"
                                                onclick="confirmarAnulacion(@p.PrestamoId)"
                                                title="Anular préstamo">
                                            <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" width="18" alt="Anular préstamo" />
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="estadisticas estadisticas-prestamo">
            <div class="stat stat-info">
                Total registrados: @totalPrestamos
            </div>
            <div class="stat stat-success">
                Activos: @prestamosActivos
            </div>
            <div class="stat stat-warning">
                Devueltos: @prestamosDevueltos
            </div>
            <div class="stat stat-danger">
                Anulados: @prestamosAnulados
            </div>
        </div>
    </div>
</div>

<div id="modal-detalles" class="modal modal-details-shell">
    <div class="modal-box modal-box-details">
        <div class="modal-icon crear">
            <img src="~/assets/icons/visibility_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-modal" alt="Detalles" />
        </div>
        <h2>Detalles del préstamo</h2>
        <p>Resumen del lector, el ejemplar y las fechas registradas.</p>
        <div id="modal-body-content" class="modal-body-custom"></div>
        <div id="comprobante-preview" class="comprobante-preview" style="display:none;"></div>
        <div class="modal-buttons">
            <button type="button" class="btn-ghost-action" onclick="toggleComprobantePreview()">Ver comprobante</button>
            <button type="button" class="btn-nuevo" onclick="descargarComprobantePdf()">Descargar PDF</button>
            <button type="button" class="btn-secondary" onclick="cerrarModal()">Cerrar</button>
        </div>
    </div>
</div>

<div id="modal-anular-prestamo" class="modal">
    <div class="modal-box">
        <div class="modal-icon">
            <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-modal" alt="Anular préstamo" />
        </div>
        <h2>Anular préstamo</h2>
        <p id="texto-anular-prestamo">¿Deseas anular este préstamo? Los ejemplares volverán a estar disponibles.</p>

        <form method="post" action="?handler=AnularPrestamo">
            @Html.AntiForgeryToken()
            <input type="hidden" id="prestamo-id-anular" name="prestamoId" />

            <div class="modal-buttons">
                <button type="submit" class="btn-danger">Confirmar anulación</button>
                <button type="button" class="btn-secondary" onclick="cerrarModalAnulacion()">Cancelar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script>
        let comprobanteActual = null;

        function formatearFecha(fecha, incluirHora = false) {
            if (!fecha) return 'No registrado';

            const valor = new Date(fecha);
            return incluirHora
                ? valor.toLocaleString()
                : valor.toLocaleDateString();
        }

        function escapeHtml(texto) {
            return (texto ?? '')
                .toString()
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#39;');
        }

        function renderComprobantePreview(comprobante) {
            const contenedor = document.getElementById('comprobante-preview');
            if (!contenedor || !comprobante) {
                return;
            }

            const librosRows = (comprobante.libros || [])
                .map((libro, idx) => `
                    <tr>
                        <td>${idx + 1}</td>
                        <td>${escapeHtml(libro.titulo || 'Sin título')}</td>
                        <td>${escapeHtml(libro.codigo || 'S/C')}</td>
                    </tr>`)
                .join('');

            contenedor.innerHTML = `
                <article class="comprobante-sheet">
                    <header class="comprobante-header">
                        <img src="/assets/images/blackLogoR.png" class="comprobante-logo" alt="Logo StarBook" />
                        <div class="comprobante-heading">
                            <h3>RECIBO DE PRÉSTAMO</h3>
                            <p>Biblioteca StarBook</p>
                        </div>
                    </header>

                    <section class="comprobante-grid comprobante-grid-rows">
                        <div class="comprobante-row">
                            <strong>Préstamo</strong>
                            <span>${escapeHtml((comprobante.prestamoId ?? '').toString())}</span>
                        </div>
                        <div class="comprobante-row comprobante-row-dual">
                            <div>
                                <strong>Nombre de lector</strong>
                                <span>${escapeHtml(comprobante.nombreLector || 'No registrado')}</span>
                            </div>
                            <div>
                                <strong>CI</strong>
                                <span>${escapeHtml(comprobante.ci || 'No registrado')}</span>
                            </div>
                        </div>
                        <div class="comprobante-row comprobante-row-dual">
                            <div>
                                <strong>Fecha de préstamo</strong>
                                <span>${formatearFecha(comprobante.fechaPrestamo, false)}</span>
                            </div>
                            <div>
                                <strong>Fecha de devolución</strong>
                                <span>${formatearFecha(comprobante.fechaDevolucion, false)}</span>
                            </div>
                        </div>
                    </section>

                    <section class="comprobante-libros">
                        <h4>Libros prestados</h4>
                        <table>
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Título</th>
                                    <th>Código</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${librosRows || '<tr><td colspan="3">Sin libros registrados.</td></tr>'}
                            </tbody>
                        </table>
                        <div class="comprobante-total-right">
                            <strong>Total de libros</strong> ${escapeHtml(String(comprobante.totalLibros ?? (comprobante.libros || []).length))}
                        </div>
                    </section>

                    <footer class="comprobante-footer-right">
                        <span>${formatearFecha(comprobante.fechaEmision, false)} - ${escapeHtml(comprobante.bibliotecario || 'No registrado')}</span>
                    </footer>
                </article>`;
        }

        function toggleComprobantePreview() {
            const preview = document.getElementById('comprobante-preview');
            if (!preview || !comprobanteActual) {
                return;
            }

            const estaVisible = preview.style.display !== 'none';
            preview.style.display = estaVisible ? 'none' : 'block';
        }

        async function obtenerComprobante(prestamoId) {
            const base = window.location.pathname;
            const response = await fetch(`${base}?handler=ComprobantePrestamo&id=${prestamoId}`);
            const data = await response.json();

            if (!data.success || !data.data) {
                throw new Error('No se pudo generar el comprobante.');
            }

            comprobanteActual = data.data;
            renderComprobantePreview(comprobanteActual);
        }

        async function logoToDataUrl(url) {
            const imagen = new Image();
            imagen.crossOrigin = 'anonymous';
            imagen.src = url;

            await new Promise((resolve, reject) => {
                imagen.onload = resolve;
                imagen.onerror = reject;
            });

            const canvas = document.createElement('canvas');
            canvas.width = imagen.width;
            canvas.height = imagen.height;
            canvas.getContext('2d')?.drawImage(imagen, 0, 0);
            return canvas.toDataURL('image/png');
        }

        async function descargarComprobantePdf() {
            if (!comprobanteActual) {
                alert('Primero abre un préstamo para generar el comprobante.');
                return;
            }

            const jsPdfNamespace = window.jspdf;
            if (!jsPdfNamespace || !jsPdfNamespace.jsPDF) {
                alert('No se pudo cargar el generador de PDF.');
                return;
            }

            const { jsPDF } = jsPdfNamespace;
            const doc = new jsPDF({ orientation: 'p', unit: 'mm', format: 'a4' });

            const margen = 12;
            const ancho = 210 - (margen * 2);

            try {
                const logoDataUrl = await logoToDataUrl('/assets/images/blackLogoR.png');
                doc.addImage(logoDataUrl, 'PNG', margen + 4, margen + 4, 44, 20);
            } catch {
                // Si el logo no carga, el comprobante igual se genera.
            }

            doc.setFont('helvetica', 'bold');
            doc.setFontSize(15);
            doc.text('RECIBO DE PRÉSTAMO - STARBOOK', margen + 60, margen + 10);
            doc.setFontSize(10);
            doc.setFont('helvetica', 'normal');
            doc.text('Biblioteca StarBook', margen + 60, margen + 16);

            let y = margen + 30;

            const drawSingleRow = (label, value) => {
                const h = 11;
                doc.setFont('helvetica', 'bold');
                doc.text(String(label), margen + 2, y + 4);
                doc.setFont('helvetica', 'normal');
                doc.text(String(value || 'No registrado'), margen + 2, y + 8.5);
                y += h;
            };

            const drawDoubleRow = (labelLeft, valueLeft, labelRight, valueRight) => {
                const h = 11;
                const colA = 120;
                const colB = ancho - colA;
                doc.setFont('helvetica', 'bold');
                doc.text(String(labelLeft), margen + 2, y + 4);
                doc.text(String(labelRight), margen + colA + 2, y + 4);
                doc.setFont('helvetica', 'normal');
                doc.text(String(valueLeft || 'No registrado'), margen + 2, y + 8.5);
                doc.text(String(valueRight || 'No registrado'), margen + colA + 2, y + 8.5);
                y += h;
            };

            drawSingleRow('PRÉSTAMO', String(comprobanteActual.prestamoId || ''));
            drawDoubleRow('NOMBRE DE LECTOR', comprobanteActual.nombreLector || 'No registrado', 'CI', comprobanteActual.ci || 'No registrado');
            drawDoubleRow('FECHA DE PRÉSTAMO', formatearFecha(comprobanteActual.fechaPrestamo, false), 'FECHA DE DEVOLUCIÓN', formatearFecha(comprobanteActual.fechaDevolucion, false));

            y += 4;
            doc.setFont('helvetica', 'bold');
            doc.text('LIBROS PRESTADOS', margen + 1, y);
            y += 3;

            doc.rect(margen, y, 12, 8);
            doc.rect(margen + 12, y, 120, 8);
            doc.rect(margen + 132, y, ancho - 132, 8);
            doc.text('#', margen + 4, y + 5);
            doc.text('TITULO', margen + 14, y + 5);
            doc.text('CODIGO', margen + 134, y + 5);
            y += 8;

            const libros = comprobanteActual.libros || [];
            if (!libros.length) {
                doc.rect(margen, y, ancho, 8);
                doc.setFont('helvetica', 'normal');
                doc.text('Sin libros registrados.', margen + 3, y + 5);
                y += 8;
            } else {
                libros.forEach((libro, index) => {
                    const titulo = String(libro.titulo || 'Sin título');
                    const codigo = String(libro.codigo || 'S/C');
                    const lineasTitulo = doc.splitTextToSize(titulo, 116);
                    const lineasCodigo = doc.splitTextToSize(codigo, ancho - 136);
                    const maxLineas = Math.max(lineasTitulo.length, lineasCodigo.length);
                    const alto = Math.max(8, 4 + maxLineas * 4);

                    doc.rect(margen, y, 12, alto);
                    doc.rect(margen + 12, y, 120, alto);
                    doc.rect(margen + 132, y, ancho - 132, alto);

                    doc.text(String(index + 1), margen + 4, y + 5);
                    doc.text(lineasTitulo, margen + 14, y + 5);
                    doc.text(lineasCodigo, margen + 134, y + 5);
                    y += alto;
                });
            }

            y += 4;
            doc.setFont('helvetica', 'bold');
            doc.text(`TOTAL DE LIBROS ${String(comprobanteActual.totalLibros || (comprobanteActual.libros || []).length)}`, margen + ancho - 70, y);

            y += 12;
            doc.setFont('helvetica', 'normal');
            const pieFirma = `${formatearFecha(comprobanteActual.fechaEmision, true)} - ${String(comprobanteActual.bibliotecario || 'No registrado')}`;
            doc.text(pieFirma, margen + ancho - doc.getTextWidth(pieFirma), y);

            const nombreArchivo = `comprobante-prestamo-${comprobanteActual.prestamoId || 'biblioteca'}.pdf`;
            doc.save(nombreArchivo);
        }

        function mostrarDetalles(prestamoId) {
            const base = window.location.pathname;
            fetch(`${base}?handler=DetallesPrestamo&id=${prestamoId}`)
                .then(response => response.json())
                .then(data => {
                    if (!data.success || !data.data) {
                        return;
                    }

                    const p = data.data;
                    const estadoTexto = p.estado === 0
                        ? 'Anulado'
                        : p.fechaDevolucionReal
                            ? 'Devuelto'
                            : 'Activo';

                    const listaLibros = (p.libros || []);
                    const listaCodigos = (p.codigos || []);
                    const librosHtml = listaLibros.length
                        ? `<ul>${listaLibros.map((libro, idx) => `<li>${escapeHtml(libro)} <small>(${escapeHtml(listaCodigos[idx] || 'S/C')})</small></li>`).join('')}</ul>`
                        : `<span>${escapeHtml(p.tituloLibro || 'Sin ejemplares')}</span>`;

                    const html = `
                        <div class="detalles-grid">
                            <div class="detalle-item">
                                <strong>ID</strong>
                                <span>#${p.prestamoId}</span>
                            </div>
                            <div class="detalle-item">
                                <strong>Estado</strong>
                                <span>${estadoTexto}</span>
                            </div>
                            <div class="detalle-item detalle-item-wide">
                                <strong>Libros</strong>
                                ${librosHtml}
                            </div>
                            <div class="detalle-item detalle-item-wide">
                                <strong>Lector</strong>
                                <span>${escapeHtml(p.nombreLector || 'Desconocido')}</span>
                            </div>
                            <div class="detalle-item">
                                <strong>Salida</strong>
                                <span>${formatearFecha(p.fechaPrestamo, true)}</span>
                            </div>
                            <div class="detalle-item">
                                <strong>Esperada</strong>
                                <span>${formatearFecha(p.fechaDevolucionEsperada, false)}</span>
                            </div>
                            <div class="detalle-item">
                                <strong>Devolución real</strong>
                                <span>${p.fechaDevolucionReal ? formatearFecha(p.fechaDevolucionReal, true) : 'Pendiente'}</span>
                            </div>
                            ${p.observacionesSalida ? `
                                <div class="detalle-obs">
                                    <strong>Observaciones de salida</strong>
                                    <p>${escapeHtml(p.observacionesSalida)}</p>
                                </div>` : ''}
                            ${p.observacionesEntrada ? `
                                <div class="detalle-obs">
                                    <strong>Observaciones de entrada</strong>
                                    <p>${escapeHtml(p.observacionesEntrada)}</p>
                                </div>` : ''}
                        </div>`;

                    document.getElementById('modal-body-content').innerHTML = html;
                    const preview = document.getElementById('comprobante-preview');
                    if (preview) {
                        preview.style.display = 'none';
                        preview.innerHTML = '';
                    }
                    obtenerComprobante(prestamoId).catch(() => {
                        comprobanteActual = null;
                    });
                    document.getElementById('modal-detalles').style.display = 'flex';
                });
        }

        function cerrarModal() {
            document.getElementById('modal-detalles').style.display = 'none';
            comprobanteActual = null;
            const preview = document.getElementById('comprobante-preview');
            if (preview) {
                preview.style.display = 'none';
                preview.innerHTML = '';
            }
        }

        window.confirmarAnulacion = function (prestamoId) {
            const inputId = document.getElementById('prestamo-id-anular');
            if (inputId) {
                inputId.value = prestamoId;
            }

            const texto = document.getElementById('texto-anular-prestamo');
            if (texto) {
                texto.textContent = `¿Deseas anular el préstamo #${prestamoId}? Los ejemplares volverán a estar disponibles.`;
            }

            const modal = document.getElementById('modal-anular-prestamo');
            if (modal) {
                modal.style.display = 'flex';
            }
        }

        function cerrarModalAnulacion() {
            const modal = document.getElementById('modal-anular-prestamo');
            if (modal) {
                modal.style.display = 'none';
            }
        }

        document.getElementById('buscador-prestamo')?.addEventListener('input', function (e) {
            const termino = (e.target.value || '').toLowerCase().trim();
            document.querySelectorAll('#tabla-prestamos-body tr').forEach(row => {
                const texto = row.innerText.toLowerCase();
                row.style.display = texto.includes(termino) ? '' : 'none';
            });
        });

        window.addEventListener('click', function (e) {
            if (e.target === document.getElementById('modal-detalles')) {
                cerrarModal();
            }

            if (e.target === document.getElementById('modal-anular-prestamo')) {
                cerrarModalAnulacion();
            }
        });
    </script>
}
