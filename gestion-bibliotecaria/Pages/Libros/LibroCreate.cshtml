@page "/Libro/Create"
@using System.Data
@model gestion_bibliotecaria.Pages.LibroCreateModel
@{
    ViewData["Title"] = "Nuevo Libro";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/libroCreate.css" />
}

<div class="libro-create-container">

    <!-- HEADER -->
    <div class="page-header">
        <div class="titulo-logo">
            @* <img src="~/assets/icons/library_books_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" *@
                    < img class="icono-header">
            <h1>Nuevo Libro</h1>
        </div>
    </div>


    <!-- FORM CARD -->
    <div class="form-card">

        <form method="post">

            <!-- AUTOR -->
            <div class="form-group">

                <label asp-for="AutorId">Autor</label>

                <select asp-for="AutorId"
                        class="input-form"
                        required>

                    <option value="">Seleccione un autor...</option>

                    @foreach (DataRow row in Model.Autores.Rows)
                    {
                        var autorId = (int)row["AutorId"];
                        var nombres = row["Nombres"]?.ToString() ?? "";
                        var apellidos = row["Apellidos"]?.ToString() ?? "";
                        var nacionalidad = row["Nacionalidad"] as string;

                        <option value="@autorId">
                            @apellidos, @nombres @(nacionalidad != null ? $"({nacionalidad})" : "")
                        </option>
                    }

                </select>

            </div>


            <!-- TITULO -->
            <div class="form-group">

                <label asp-for="Titulo">Título</label>

                <input asp-for="Titulo"
                        class="input-form"
                        placeholder="Título del libro"
                        required />

                <span asp-validation-for="Titulo" class="text-danger"></span>

            </div>


            <!-- EDITORIAL -->
            <div class="form-group">

                <label asp-for="Editorial">Editorial</label>

                <input asp-for="Editorial"
                        class="input-form"
                        placeholder="Ej: Penguin Books, Planeta" />

                <span asp-validation-for="Editorial" class="text-danger"></span>

            </div>


            <!-- EDICION -->
            <div class="form-group">

                <label asp-for="Edicion">Edición</label>

                <div class="custom-select-wrapper">
                    <input type="hidden" id="edicion-value" name="Edicion" />

                    <div class="custom-select" id="custom-select-edicion">
                        <div class="select-trigger">
                            <span id="select-text">-- Seleccione una edición --</span>
                            <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </div>

                        <div class="select-dropdown">
                            <input type="text" class="select-search" id="edicion-search" placeholder="Buscar edición..." />

                            <div class="select-options">
                                <div class="option-group">
                                    <div class="option-group-label">Ediciones Numéricas</div>
                                    <div class="option" data-value="1ra Edición">1ra Edición</div>
                                    <div class="option" data-value="2da Edición">2da Edición</div>
                                    <div class="option" data-value="3ra Edición">3ra Edición</div>
                                    <div class="option" data-value="4ta Edición">4ta Edición</div>
                                    <div class="option" data-value="5ta Edición">5ta Edición</div>
                                    <div class="option" data-value="6ta Edición">6ta Edición</div>
                                    <div class="option" data-value="7ma Edición">7ma Edición</div>
                                    <div class="option" data-value="8va Edición">8va Edición</div>
                                    <div class="option" data-value="9na Edición">9na Edición</div>
                                    <div class="option" data-value="10ma Edición">10ma Edición</div>
                                </div>

                                <div class="option-group">
                                    <div class="option-group-label">Académicas y Técnicas</div>
                                    <div class="option" data-value="Edición Revisada">Edición Revisada</div>
                                    <div class="option" data-value="Edición Actualizada">Edición Actualizada</div>
                                    <div class="option" data-value="Edición Ampliada">Edición Ampliada</div>
                                    <div class="option" data-value="Edición Internacional">Edición Internacional</div>
                                </div>

                                <div class="option-group">
                                    <div class="option-group-label">Formatos Especiales</div>
                                    <div class="option" data-value="Edición de Bolsillo">Edición de Bolsillo</div>
                                    <div class="option" data-value="Edición Ilustrada">Edición Ilustrada</div>
                                    <div class="option" data-value="Edición Especial">Edición Especial / Conmemorativa</div>
                                    <div class="option" data-value="Edición Crítica">Edición Crítica</div>
                                </div>

                                <div class="option-group">
                                    <div class="option-group-label">Otros</div>
                                    <div class="option" data-value="Otra">Otra / No especificada</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <span asp-validation-for="Edicion" class="text-danger"></span>

            </div>


            <!-- AÑO PUBLICACION -->
            <div class="form-group">

                <label asp-for="AñoPublicacion">
                    Año de Publicación
                </label>

                <input asp-for="AñoPublicacion"
                        class="input-form"
                        type="number"
                        min="1000"
                        max="2100"
                        placeholder="Ej: 2024" />

            </div>


            <!-- DESCRIPCION -->
            <div class="form-group">

                <label asp-for="Descripcion">
                    Descripción
                </label>

                <textarea asp-for="Descripcion"
                            class="input-form"
                            rows="4"
                            placeholder="Descripción breve del contenido del libro">
                </textarea>

                <span asp-validation-for="Descripcion" class="text-danger"></span>

            </div>


            <!-- ESTADO -->
            <div class="form-check">

                <input asp-for="Estado"
                        class="check-input"
                        type="checkbox"
                        checked />

                <label>
                    Activo en el sistema
                </label>

            </div>


            <!-- BOTONES -->
            <div class="form-actions">

                <button type="submit"
                        class="btn-guardar">
                    Guardar
                </button>

                <a href="/Libro"
                    class="btn-cancelar">
                    Cancelar
                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const customSelect = document.getElementById('custom-select-edicion');
            const trigger = customSelect.querySelector('.select-trigger');
            const dropdown = customSelect.querySelector('.select-dropdown');
            const search = customSelect.querySelector('.select-search');
            const options = customSelect.querySelectorAll('.option');
            const hiddenInput = document.getElementById('edicion-value');
            const selectText = document.getElementById('select-text');
            let isOpen = false;

            // Toggle dropdown
            trigger.addEventListener('click', function(e) {
                e.stopPropagation();
                isOpen = !isOpen;
                customSelect.classList.toggle('active', isOpen);
                if (isOpen) {
                    search.focus();
                    search.value = '';
                    options.forEach(opt => opt.classList.remove('hidden'));
                }
            });

            // Close when clicking outside
            document.addEventListener('click', function(e) {
                if (!customSelect.contains(e.target)) {
                    isOpen = false;
                    customSelect.classList.remove('active');
                }
            });

            // Search functionality
            search.addEventListener('input', function() {
                const searchTerm = this.value.toLowerCase();
                options.forEach(option => {
                    const text = option.textContent.toLowerCase();
                    option.classList.toggle('hidden', !text.includes(searchTerm));
                });
            });

            // Select option
            options.forEach(option => {
                option.addEventListener('click', function(e) {
                    e.stopPropagation();
                    const value = this.dataset.value;
                    const text = this.textContent;
                    hiddenInput.value = value;
                    selectText.textContent = text;
                    isOpen = false;
                    customSelect.classList.remove('active');

                    // Trigger change event for validation
                    hiddenInput.dispatchEvent(new Event('change', { bubbles: true }));
                });

                // Keyboard navigation
                option.addEventListener('mouseenter', function() {
                    options.forEach(opt => opt.classList.remove('highlight'));
                    this.classList.add('highlight');
                });
            });

            // Arrow key navigation
            search.addEventListener('keydown', function(e) {
                const visibleOptions = Array.from(options).filter(opt => !opt.classList.contains('hidden'));
                const currentIndex = visibleOptions.findIndex(opt => opt.classList.contains('highlight'));

                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    const nextIndex = Math.min(currentIndex + 1, visibleOptions.length - 1);
                    visibleOptions.forEach(opt => opt.classList.remove('highlight'));
                    visibleOptions[nextIndex].classList.add('highlight');
                    visibleOptions[nextIndex].scrollIntoView({ block: 'nearest' });
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    const prevIndex = Math.max(currentIndex - 1, 0);
                    visibleOptions.forEach(opt => opt.classList.remove('highlight'));
                    visibleOptions[prevIndex].classList.add('highlight');
                    visibleOptions[prevIndex].scrollIntoView({ block: 'nearest' });
                } else if (e.key === 'Enter') {
                    e.preventDefault();
                    const highlighted = Array.from(options).find(opt => opt.classList.contains('highlight'));
                    if (highlighted) {
                        highlighted.click();
                    }
                }
            });

            // Set initial value if exists
            const initialValue = hiddenInput.value;
            if (initialValue) {
                const matchedOption = Array.from(options).find(opt => opt.dataset.value === initialValue);
                if (matchedOption) {
                    selectText.textContent = matchedOption.textContent;
                }
            }
        });
    </script>
    }
