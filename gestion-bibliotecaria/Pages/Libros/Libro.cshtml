@page "/Libro"
@using System.Data
@model gestion_bibliotecaria.Pages.LibroModel
@{
    ViewData["Title"] = "Gestión de Libros";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/Libros.css" />
}

<div class="libros-container">

    <div class="page-header">

        <div class="titulo-logo">
            <h1>Gestión de Libros</h1>
        </div>

        <a href="/Libro/Create" class="btn-nuevo">
            <img src="~/assets/icons/add_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                 class="icono-btn icon-white">
            Nuevo Libro
        </a>

    </div>

@if (Model.Libros.Rows.Count == 0)
{
    <div class="alert alert-info">
        No hay libros registrados en el sistema.
    </div>
}
else
{
    var total = Model.Libros.Rows.Count;
    var activos = 0;

    foreach (DataRow row in Model.Libros.Rows)
    {
        if (row.Field<bool>("Estado"))
        {
            activos++;
        }
    }

    var inactivos = total - activos;

    <div class="filtros-barra">
        <div class="filtro-item filtro-buscar">
            <input id="buscador-libro"
                   type="text"
                   class="input-filtro"
                   placeholder="Buscar por título, autor, editorial o estado..."
                   autocomplete="off" />
        </div>

        <div class="filtro-item">
            <select id="orden-libro" class="input-filtro">
                <option value="titulo_asc">Título A-Z</option>
                <option value="titulo_desc">Título Z-A</option>
            </select>
        </div>
    </div>

    <div class="tabla-container">

        <table id="tabla-libro" class="tabla-libros">

            <thead>
                <tr>
                    <th>Título</th>
                    <th>Autor</th>
                    <th>Editorial</th>
                    <th>Edición</th>
                    <th>Año</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>

            @foreach (DataRow row in Model.Libros.Rows)
            {
                var libroToken = row.Field<string>("LibroToken") ?? string.Empty;
                var autorId = row.Field<int>("AutorId");
                var titulo = row.Field<string>("Titulo");
                var editorial = row.Field<string>("Editorial");
                var edicion = row.Field<string>("Edicion");
                var añoPublicacion = row.Field<int?>("AñoPublicacion");
                var estado = row.Field<bool>("Estado");

                <tr class="@(!estado ? "fila-inactiva" : "")">

                    <td><strong>@titulo</strong></td>

                    <td>
                        @if (Model.AutoresNombres.TryGetValue(autorId, out var nombreAutor))
                        {
                            <span>@nombreAutor</span>
                        }
                        else
                        {
                            <span class="text-muted">Autor #@autorId</span>
                        }
                    </td>

                    <td>@(editorial ?? "N/A")</td>
                    <td>@(edicion ?? "N/A")</td>
                    <td>@(añoPublicacion?.ToString() ?? "N/A")</td>

                    <td>
                        @if (estado)
                        {
                            <span class="estado activo">Activo</span>
                        }
                        else
                        {
                            <span class="estado inactivo">Inactivo</span>
                        }
                    </td>

                    <td class="acciones">

                        <a href="/Libro/Edit/@libroToken" class="btn-editar">
                            <img src="~/assets/icons/edit_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                 class="icono-btn icon-white">
                            Editar
                        </a>

                        <!-- BOTON MODAL -->
                        <button class="btn-eliminar"
                                onclick="abrirModalEliminar('@libroToken')">

                            <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                 class="icono-btn icon-white">

                            Eliminar
                        </button>

                    </td>

                </tr>
            }

            </tbody>

            <tr id="fila-sin-resultados" style="display:none;">
                <td colspan="7" style="text-align:center; padding:20px; color:#9ca3af;">
                    No hay libros que coincidan con la búsqueda.
                </td>
            </tr>

        </table>

    </div>

    <div class="estadisticas">
        <div class="stat stat-info">Total libros: @total</div>
        <div class="stat stat-success">Activos: @activos</div>
        <div class="stat stat-secondary">Inactivos: @inactivos</div>
    </div>
}

</div>

<!-- MODAL -->
<div id="modalEliminar" class="modal">

    <div class="modal-box">

        <div class="modal-icon">
            <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                 class="icono-modal">
        </div>

        <h2>¿Estás seguro de que quieres eliminar este libro?</h2>

        <p>Esta acción no se puede deshacer.</p>

        <div class="modal-buttons">

            <a id="btnConfirmarEliminar" class="btn-danger">
                Sí, eliminar
            </a>

            <button class="btn-secondary" onclick="cerrarModalEliminar()">
                Cancelar
            </button>

        </div>

    </div>

</div>

@section Scripts {
<script>
    (function () {
        var input = document.getElementById('buscador-libro');
        var select = document.getElementById('orden-libro');
        var tabla = document.getElementById('tabla-libro');

        if (!input || !tabla) return;

        function normalizar(s) {
            return (s || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim();
        }

        function aplicar() {
            var termino = normalizar(input.value);
            var orden = select ? select.value : 'titulo_asc';

            var tbody = tabla.querySelector('tbody');
            var filas = Array.from(tbody.querySelectorAll('tr:not(#fila-sin-resultados)'));

            var asc = orden.endsWith('_asc');

            filas.sort(function (a, b) {
                var va = normalizar(a.cells[0].textContent);
                var vb = normalizar(b.cells[0].textContent);
                return asc ? va.localeCompare(vb) : vb.localeCompare(va);
            });

            filas.forEach(f => tbody.appendChild(f));

            var visibles = 0;

            filas.forEach(function (fila) {
                var texto = normalizar(fila.textContent);
                var coincide = termino === '' || texto.includes(termino);
                fila.style.display = coincide ? '' : 'none';
                if (coincide) visibles++;
            });

            var sinResultados = document.getElementById('fila-sin-resultados');

            if (sinResultados) {
                sinResultados.style.display = visibles === 0 ? '' : 'none';
                tbody.appendChild(sinResultados);
            }
        }

        input.addEventListener('input', aplicar);
        if (select) select.addEventListener('change', aplicar);

        aplicar();
    })();

    function abrirModalEliminar(token) {
        var url = "/Libro/Delete/" + token;
        document.getElementById("btnConfirmarEliminar").href = url;
        document.getElementById("modalEliminar").style.display = "flex";
    }

    function cerrarModalEliminar() {
        document.getElementById("modalEliminar").style.display = "none";
    }

    // cerrar al hacer click fuera
    window.onclick = function(e) {
        var modal = document.getElementById("modalEliminar");
        if (e.target === modal) {
            cerrarModalEliminar();
        }
    }
</script>
}