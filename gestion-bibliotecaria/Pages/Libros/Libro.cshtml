                if (autorId) {
                    const autorOpt = document.querySelector('#custom-select-autor-create .option[data-value="' + autorId + '"]');
                    if (autorOpt) {
                        document.getElementById("createAutorText").textContent = autorOpt.textContent.trim();
                        document.getElementById("autor-search-create").value = autorOpt.textContent.trim();
                    }
                } else if (autorNuevo) {
