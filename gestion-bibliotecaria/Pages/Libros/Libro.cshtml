@page "/Libro"
@using System.Data
@using System.Linq
@model gestion_bibliotecaria.Pages.LibroModel
@{
    ViewData["Title"] = "Gestión de Libros";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/Libros.css" />
}

<div class="libros-container">

    <div class="page-header">

        <div class="titulo-logo">
            <h1>Gestión de Libros</h1>
        </div>

        <button type="button" class="btn-nuevo" onclick="abrirModalCrear()">
            <img src="~/assets/icons/add_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                 class="icono-btn icon-white">
            Nuevo Libro
        </button>

    </div>

@if (Model.Libros.Rows.Count == 0)
{
    <div class="alert alert-info">
        No hay libros registrados en el sistema.
    </div>
}
else
{
    var total = Model.Libros.Rows.Count;
    var activos = 0;

    foreach (DataRow row in Model.Libros.Rows)
    {
        if (row.Field<bool>("Estado"))
        {
            activos++;
        }
    }

    var inactivos = total - activos;

    <div class="filtros-barra">
        <div class="filtro-item filtro-buscar">
            <input id="buscador-libro"
                   type="text"
                   class="input-filtro"
                   placeholder="Buscar por título, autor, editorial o estado..."
                   autocomplete="off" />
        </div>

        @* <div class="filtro-item">
            <select id="orden-libro" class="input-filtro">
                <option value="titulo_asc">Título A-Z</option>
                <option value="titulo_desc">Título Z-A</option>
            </select>
        </div> *@
    </div>

    <div class="tabla-container">

        <table id="tabla-libro" class="tabla-libros">

            <thead>
                <tr>
                    <th>Título</th>
                    <th>Autor</th>
                    <th>Editorial</th>
                    <th>Edición</th>
                    <th>Año</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>

            @foreach (DataRow row in Model.Libros.Rows)
            {
                var libroToken = row.Field<string>("LibroToken") ?? string.Empty;
                var autorId = row.Field<int>("AutorId");
                var titulo = row.Field<string>("Titulo");
                var editorial = row.Field<string>("Editorial");
                var edicion = row.Field<string>("Edicion");
                var añoPublicacion = row.Field<int?>("AñoPublicacion");
                var estado = row.Field<bool>("Estado");
                var descripcion = row.Table.Columns.Contains("Descripcion") ? row["Descripcion"]?.ToString() : "";

                <tr class="@(!estado ? "fila-inactiva" : "")">

                    <td><strong>@titulo</strong></td>

                    <td>
                        @if (Model.AutoresNombres.TryGetValue(autorId, out var nombreAutor))
                        {
                            <span>@nombreAutor</span>
                        }
                        else
                        {
                            <span class="text-muted">Autor #@autorId</span>
                        }
                    </td>

                    <td>@(editorial ?? "N/A")</td>
                    <td>@(edicion ?? "N/A")</td>
                    <td>@(añoPublicacion?.ToString() ?? "N/A")</td>

                    <td>
                        @if (estado)
                        {
                            <span class="estado activo">Activo</span>
                        }
                        else
                        {
                            <span class="estado inactivo">Inactivo</span>
                        }
                    </td>

                    <td class="acciones">

                        <button type="button"
                                class="btn-editar"
                                onclick="abrirModalEditar(
                                    '@libroToken',
                                    '@autorId',
                                    '@Html.Raw((titulo ?? "").Replace("'", "\\'"))',
                                    '@Html.Raw((editorial ?? "").Replace("'", "\\'"))',
                                    '@Html.Raw((edicion ?? "").Replace("'", "\\'"))',
                                    '@(añoPublicacion?.ToString() ?? "")',
                                    '@Html.Raw((descripcion ?? "").Replace("'", "\\'"))',
                                    '@estado'
                                )">

                            <img src="~/assets/icons/edit_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                 class="icono-btn icon-white">
                            Editar
                        </button>

                        <button type="button"
                                class="btn-eliminar"
                                onclick="abrirModalEliminar('@libroToken')">

                            <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                 class="icono-btn icon-white">

                            Eliminar
                        </button>

                    </td>

                </tr>
            }

            </tbody>

            <tr id="fila-sin-resultados" style="display:none;">
                <td colspan="7" style="text-align:center; padding:20px; color:#9ca3af;">
                    No hay libros que coincidan con la búsqueda.
                </td>
            </tr>

        </table>

    </div>

    <div class="estadisticas">
        <div class="stat stat-info">Total libros: @total</div>
        <div class="stat stat-success">Activos: @activos</div>
        <div class="stat stat-secondary">Inactivos: @inactivos</div>
    </div>
}

</div>

<!-- MODAL ELIMINAR -->
<div id="modalEliminar" class="modal">
    <div class="modal-box">

        <div class="modal-icon">
            <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                 class="icono-modal">
        </div>

        <h2>¿Estás seguro de que quieres eliminar este libro?</h2>
        <p>Esta acción no se puede deshacer.</p>

        <form method="post" asp-page-handler="Eliminar">
            @Html.AntiForgeryToken()

            <input type="hidden" id="libroTokenInput" name="token" />

            <div class="modal-buttons">
                <button type="submit" class="btn-danger">
                    Sí, eliminar
                </button>

                <button type="button" class="btn-secondary" onclick="cerrarModalEliminar()">
                    Cancelar
                </button>
            </div>
        </form>

    </div>
</div>

<!-- MODAL EDITAR -->
<div id="modalEditar" class="modal">
    <div class="modal-box">

        <div class="modal-icon editar">
            <img src="~/assets/icons/edit_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                 class="icono-modal">
        </div>

        <h2>Editar libro</h2>
        <p>Modifica la información del libro.</p>

        <form method="post" asp-page-handler="Editar">
            @Html.AntiForgeryToken()

            <input type="hidden" id="editToken" name="token" />
            <input type="hidden" id="editFechaRegistro" name="FechaRegistro" />

            @if (ViewData.ModelState.ContainsKey(string.Empty))
            {
                <div class="text-error-summary">
                    @foreach (var error in ViewData.ModelState[string.Empty]!.Errors)
                    {
                        <div>• @error.ErrorMessage</div>
                    }
                </div>
            }

            <!-- AUTOR -->
            <div class="custom-select-wrapper">
                <input type="hidden" id="editAutorId" name="AutorId" />

                <div class="custom-select" id="custom-select-autor-edit">
                    <div class="select-trigger">
                        <span id="editAutorText">-- Seleccione un autor --</span>
                        <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>

                    <div class="select-dropdown">
                        <input type="text"
                               class="select-search"
                               id="autor-search-edit"
                               placeholder="Buscar autor..." />

                        <div class="select-options">
                            @foreach (DataRow autorRow in Model.Autores.Rows)
                            {
                                var aId = (int)autorRow["AutorId"];
                                var nombres = autorRow["Nombres"]?.ToString() ?? "";
                                var apellidos = autorRow["Apellidos"]?.ToString() ?? "";
                                var nacionalidad = autorRow["Nacionalidad"] as string;
                                var textoAutor = $"{apellidos}, {nombres}" + (!string.IsNullOrWhiteSpace(nacionalidad) ? $" ({nacionalidad})" : "");

                                <div class="option" data-value="@aId">@textoAutor</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- TITULO -->
            <input type="text" id="editTitulo" name="Titulo" placeholder="Título" required />
            @if (ViewData.ModelState.ContainsKey("Titulo"))
            {
                <span class="text-error">
                    @ViewData.ModelState["Titulo"]?.Errors.FirstOrDefault()?.ErrorMessage
                </span>
            }

            <!-- EDITORIAL -->
            <input type="text" id="editEditorial" name="Editorial" placeholder="Editorial" />
            @if (ViewData.ModelState.ContainsKey("Editorial"))
            {
                <span class="text-error">
                    @ViewData.ModelState["Editorial"]?.Errors.FirstOrDefault()?.ErrorMessage
                </span>
            }

            <!-- EDICION -->
            <div class="custom-select-wrapper">
                <input type="hidden" id="editEdicion" name="Edicion" />

                <div class="custom-select" id="custom-select-edicion-edit">
                    <div class="select-trigger">
                        <span id="editEdicionText">-- Seleccione una edición --</span>
                        <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>

                    <div class="select-dropdown">
                        <input type="text"
                               class="select-search"
                               id="edicion-search-edit"
                               placeholder="Buscar edición..." />

                        <div class="select-options">
                            <div class="option" data-value="1ra Edición">1ra Edición</div>
                            <div class="option" data-value="2da Edición">2da Edición</div>
                            <div class="option" data-value="3ra Edición">3ra Edición</div>
                            <div class="option" data-value="4ta Edición">4ta Edición</div>
                            <div class="option" data-value="5ta Edición">5ta Edición</div>
                            <div class="option" data-value="6ta Edición">6ta Edición</div>
                            <div class="option" data-value="7ma Edición">7ma Edición</div>
                            <div class="option" data-value="8va Edición">8va Edición</div>
                            <div class="option" data-value="9na Edición">9na Edición</div>
                            <div class="option" data-value="10ma Edición">10ma Edición</div>
                            <div class="option" data-value="Edición Revisada">Edición Revisada</div>
                            <div class="option" data-value="Edición Actualizada">Edición Actualizada</div>
                            <div class="option" data-value="Edición Ampliada">Edición Ampliada</div>
                            <div class="option" data-value="Edición Internacional">Edición Internacional</div>
                            <div class="option" data-value="Edición de Bolsillo">Edición de Bolsillo</div>
                            <div class="option" data-value="Edición Ilustrada">Edición Ilustrada</div>
                            <div class="option" data-value="Edición Especial">Edición Especial / Conmemorativa</div>
                            <div class="option" data-value="Edición Crítica">Edición Crítica</div>
                            <div class="option" data-value="Otra">Otra / No especificada</div>
                        </div>
                    </div>
                </div>
            </div>
            @if (ViewData.ModelState.ContainsKey("Edicion"))
            {
                <span class="text-error">
                    @ViewData.ModelState["Edicion"]?.Errors.FirstOrDefault()?.ErrorMessage
                </span>
            }

            <!-- AÑO -->
            <input type="number"
                   id="editAnioPublicacion"
                   name="AñoPublicacion"
                   placeholder="Año de publicación"
                   min="1000"
                   max="2100" />
            @if (ViewData.ModelState.ContainsKey("AñoPublicacion"))
            {
                <span class="text-error">
                    @ViewData.ModelState["AñoPublicacion"]?.Errors.FirstOrDefault()?.ErrorMessage
                </span>
            }

            <!-- DESCRIPCION -->
            <textarea id="editDescripcion"
                      name="Descripcion"
                      placeholder="Descripción"
                      rows="4"></textarea>
            @if (ViewData.ModelState.ContainsKey("Descripcion"))
            {
                <span class="text-error">
                    @ViewData.ModelState["Descripcion"]?.Errors.FirstOrDefault()?.ErrorMessage
                </span>
            }

            <!-- ESTADO -->
            <select id="editEstado" name="Estado">
                <option value="true">Activo</option>
                <option value="false">Inactivo</option>
            </select>

            <div class="modal-buttons">
                <button type="submit" class="btn-warning">Guardar cambios</button>
                <button type="button" class="btn-secondary" onclick="cerrarModalEditar()">Cancelar</button>
            </div>
        </form>

    </div>
</div>

<!-- MODAL CREAR -->
<div id="modalCrear" class="modal">
    <div class="modal-box">

        <div class="modal-icon crear">
            <img src="~/assets/icons/add_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                 class="icono-modal">
        </div>

        <h2>Nuevo libro</h2>
        <p>Ingresa la información del libro.</p>

        <form method="post" asp-page-handler="Crear">
            @Html.AntiForgeryToken()

            @if (ViewData.ModelState.ContainsKey(string.Empty))
            {
                <div class="text-error-summary">
                    @foreach (var error in ViewData.ModelState[string.Empty]!.Errors)
                    {
                        <div>• @error.ErrorMessage</div>
                    }
                </div>
            }

            <!-- AUTOR -->
            <div class="custom-select-wrapper">
                <input type="hidden" id="createAutorId" name="AutorId" />

                <div class="custom-select" id="custom-select-autor-create">
                    <div class="select-trigger">
                        <span id="createAutorText">Seleccione un autor...</span>
                        <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>

                    <div class="select-dropdown">
                        <input type="text"
                               class="select-search"
                               id="autor-search-create"
                               placeholder="Buscar autor..." />

                        <div class="select-options">
                            @foreach (DataRow autorRow in Model.Autores.Rows)
                            {
                                var aId = (int)autorRow["AutorId"];
                                var nombres = autorRow["Nombres"]?.ToString() ?? "";
                                var apellidos = autorRow["Apellidos"]?.ToString() ?? "";
                                var nacionalidad = autorRow["Nacionalidad"] as string;
                                var displayText = $"{apellidos}, {nombres}{(!string.IsNullOrWhiteSpace(nacionalidad) ? $" ({nacionalidad})" : "")}";

                                <div class="option"
                                     data-value="@aId"
                                     data-text="@displayText">
                                    @displayText
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- TITULO -->
            <input type="text"
                   id="createTitulo"
                   name="Titulo"
                   placeholder="Título del libro"
                   required />
            @if (ViewData.ModelState.ContainsKey("Titulo"))
            {
                <span class="text-error">
                    @ViewData.ModelState["Titulo"]?.Errors.FirstOrDefault()?.ErrorMessage
                </span>
            }

            <!-- EDITORIAL -->
            <input type="text"
                   id="createEditorial"
                   name="Editorial"
                   placeholder="Ej: Penguin Books, Planeta" />
            @if (ViewData.ModelState.ContainsKey("Editorial"))
            {
                <span class="text-error">
                    @ViewData.ModelState["Editorial"]?.Errors.FirstOrDefault()?.ErrorMessage
                </span>
            }

            <!-- EDICION -->
            <div class="custom-select-wrapper">
                <input type="hidden" id="createEdicion" name="Edicion" />

                <div class="custom-select" id="custom-select-edicion-create">
                    <div class="select-trigger">
                        <span id="createEdicionText">-- Seleccione una edición --</span>
                        <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>

                    <div class="select-dropdown">
                        <input type="text"
                               class="select-search"
                               id="edicion-search-create"
                               placeholder="Buscar edición..." />

                        <div class="select-options">
                            <div class="option" data-value="1ra Edición">1ra Edición</div>
                            <div class="option" data-value="2da Edición">2da Edición</div>
                            <div class="option" data-value="3ra Edición">3ra Edición</div>
                            <div class="option" data-value="4ta Edición">4ta Edición</div>
                            <div class="option" data-value="5ta Edición">5ta Edición</div>
                            <div class="option" data-value="6ta Edición">6ta Edición</div>
                            <div class="option" data-value="7ma Edición">7ma Edición</div>
                            <div class="option" data-value="8va Edición">8va Edición</div>
                            <div class="option" data-value="9na Edición">9na Edición</div>
                            <div class="option" data-value="10ma Edición">10ma Edición</div>
                            <div class="option" data-value="Edición Revisada">Edición Revisada</div>
                            <div class="option" data-value="Edición Actualizada">Edición Actualizada</div>
                            <div class="option" data-value="Edición Ampliada">Edición Ampliada</div>
                            <div class="option" data-value="Edición Internacional">Edición Internacional</div>
                            <div class="option" data-value="Edición de Bolsillo">Edición de Bolsillo</div>
                            <div class="option" data-value="Edición Ilustrada">Edición Ilustrada</div>
                            <div class="option" data-value="Edición Especial">Edición Especial / Conmemorativa</div>
                            <div class="option" data-value="Edición Crítica">Edición Crítica</div>
                            <div class="option" data-value="Otra">Otra / No especificada</div>
                        </div>
                    </div>
                </div>
            </div>
            @if (ViewData.ModelState.ContainsKey("Edicion"))
            {
                <span class="text-error">
                    @ViewData.ModelState["Edicion"]?.Errors.FirstOrDefault()?.ErrorMessage
                </span>
            }

            <!-- AÑO -->
            <input type="number"
                   id="createAnioPublicacion"
                   name="AñoPublicacion"
                   placeholder="Año de publicación"
                   min="1000"
                   max="2100" />
            @if (ViewData.ModelState.ContainsKey("AñoPublicacion"))
            {
                <span class="text-error">
                    @ViewData.ModelState["AñoPublicacion"]?.Errors.FirstOrDefault()?.ErrorMessage
                </span>
            }

            <!-- DESCRIPCION -->
            <textarea id="createDescripcion"
                      name="Descripcion"
                      placeholder="Descripción breve del contenido del libro"
                      rows="4"></textarea>
            @if (ViewData.ModelState.ContainsKey("Descripcion"))
            {
                <span class="text-error">
                    @ViewData.ModelState["Descripcion"]?.Errors.FirstOrDefault()?.ErrorMessage
                </span>
            }

            <!-- ESTADO -->
            <select id="createEstado" name="Estado">
                <option value="true" selected>Activo</option>
                <option value="false">Inactivo</option>
            </select>

            <div class="modal-buttons">
                <button type="submit" class="btn-success">Crear libro</button>
                <button type="button" class="btn-secondary" onclick="cerrarModalCrear()">Cancelar</button>
            </div>
        </form>

    </div>
</div>

@section Scripts {
<script>
(function () {
    var input = document.getElementById('buscador-libro');
    var select = document.getElementById('orden-libro');
    var tabla = document.getElementById('tabla-libro');

    if (!input || !tabla) return;

    function normalizar(s) {
        return (s || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim();
    }

    function aplicar() {
        var termino = normalizar(input.value);
        var orden = select ? select.value : 'titulo_asc';

        var tbody = tabla.querySelector('tbody');
        var filas = Array.from(tbody.querySelectorAll('tr:not(#fila-sin-resultados)'));

        var asc = orden.endsWith('_asc');

        filas.sort(function (a, b) {
            var va = normalizar(a.cells[0].textContent);
            var vb = normalizar(b.cells[0].textContent);
            return asc ? va.localeCompare(vb) : vb.localeCompare(va);
        });

        filas.forEach(f => tbody.appendChild(f));

        var visibles = 0;

        filas.forEach(function (fila) {
            var texto = normalizar(fila.textContent);
            var coincide = termino === '' || texto.includes(termino);
            fila.style.display = coincide ? '' : 'none';
            if (coincide) visibles++;
        });

        var sinResultados = document.getElementById('fila-sin-resultados');
        if (sinResultados) {
            sinResultados.style.display = visibles === 0 ? '' : 'none';
            tbody.appendChild(sinResultados);
        }
    }

    input.addEventListener('input', aplicar);
    if (select) select.addEventListener('change', aplicar);

    aplicar();
})();

function abrirModalEliminar(token) {
    document.getElementById("libroTokenInput").value = token;
    document.getElementById("modalEliminar").style.display = "flex";
}

function cerrarModalEliminar() {
    document.getElementById("modalEliminar").style.display = "none";
}

function abrirModalEditar(token, autorId, titulo, editorial, edicion, anio, descripcion, estado) {
    document.getElementById("editToken").value = token;
    document.getElementById("editAutorId").value = autorId;
    document.getElementById("editTitulo").value = titulo || "";
    document.getElementById("editEditorial").value = editorial || "";
    document.getElementById("editEdicion").value = edicion || "";
    document.getElementById("editAnioPublicacion").value = anio || "";
    document.getElementById("editDescripcion").value = descripcion || "";
    document.getElementById("editEstado").value = estado === "True" ? "true" : "false";

    const autorOption = document.querySelector('#custom-select-autor-edit .option[data-value="' + autorId + '"]');
    document.getElementById("editAutorText").textContent =
        autorOption ? autorOption.textContent.trim() : "-- Seleccione un autor --";

    const edicionOption = document.querySelector('#custom-select-edicion-edit .option[data-value="' + edicion + '"]');
    document.getElementById("editEdicionText").textContent =
        edicionOption ? edicionOption.textContent.trim() : (edicion || "-- Seleccione una edición --");

    document.getElementById("modalEditar").style.display = "flex";
}

function cerrarModalEditar() {
    document.getElementById("modalEditar").style.display = "none";
}

function abrirModalCrear() {
    document.getElementById("createAutorId").value = "";
    document.getElementById("createAutorText").textContent = "Seleccione un autor...";
    document.getElementById("createTitulo").value = "";
    document.getElementById("createEditorial").value = "";
    document.getElementById("createEdicion").value = "";
    document.getElementById("createEdicionText").textContent = "-- Seleccione una edición --";
    document.getElementById("createAnioPublicacion").value = "";
    document.getElementById("createDescripcion").value = "";
    document.getElementById("createEstado").value = "true";

    document.getElementById("modalCrear").style.display = "flex";
}

function cerrarModalCrear() {
    document.getElementById("modalCrear").style.display = "none";
}

document.addEventListener('DOMContentLoaded', function () {

    function initCustomSelect(config) {
        const customSelect = document.getElementById(config.selectId);
        if (!customSelect) return;

        const trigger = customSelect.querySelector('.select-trigger');
        const search = customSelect.querySelector('.select-search');
        const options = customSelect.querySelectorAll('.option');
        const hiddenInput = document.getElementById(config.hiddenInputId);
        const selectText = document.getElementById(config.textId);
        let isOpen = false;

        trigger.addEventListener('click', function (e) {
            e.stopPropagation();
            isOpen = !isOpen;
            customSelect.classList.toggle('active', isOpen);

            if (isOpen) {
                search.focus();
                search.value = '';
                options.forEach(opt => opt.classList.remove('hidden'));
            }
        });

        document.addEventListener('click', function (e) {
            if (!customSelect.contains(e.target)) {
                isOpen = false;
                customSelect.classList.remove('active');
            }
        });

        search.addEventListener('input', function () {
            const searchTerm = this.value.toLowerCase();

            options.forEach(option => {
                const text = option.textContent.toLowerCase();
                option.classList.toggle('hidden', !text.includes(searchTerm));
            });
        });

        options.forEach(option => {
            option.addEventListener('click', function (e) {
                e.stopPropagation();

                const value = this.dataset.value;
                const text = this.dataset.text || this.textContent.trim();

                hiddenInput.value = value;
                selectText.textContent = text;
                isOpen = false;
                customSelect.classList.remove('active');
            });
        });
    }

    initCustomSelect({
        selectId: 'custom-select-autor-edit',
        hiddenInputId: 'editAutorId',
        textId: 'editAutorText'
    });

    initCustomSelect({
        selectId: 'custom-select-edicion-edit',
        hiddenInputId: 'editEdicion',
        textId: 'editEdicionText'
    });

    initCustomSelect({
        selectId: 'custom-select-autor-create',
        hiddenInputId: 'createAutorId',
        textId: 'createAutorText'
    });

    initCustomSelect({
        selectId: 'custom-select-edicion-create',
        hiddenInputId: 'createEdicion',
        textId: 'createEdicionText'
    });
});

window.onclick = function(e) {
    var modalEliminar = document.getElementById("modalEliminar");
    var modalEditar = document.getElementById("modalEditar");
    var modalCrear = document.getElementById("modalCrear");

    if (e.target === modalEliminar) cerrarModalEliminar();
    if (e.target === modalEditar) cerrarModalEditar();
    if (e.target === modalCrear) cerrarModalCrear();
}
</script>

@if (!ViewData.ModelState.IsValid)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var errorEditar =
                @Html.Raw((
                    ViewData.ModelState.ContainsKey("Titulo") ||
                    ViewData.ModelState.ContainsKey("Editorial") ||
                    ViewData.ModelState.ContainsKey("Edicion") ||
                    ViewData.ModelState.ContainsKey("AñoPublicacion") ||
                    ViewData.ModelState.ContainsKey("Descripcion") ||
                    ViewData.ModelState.ContainsKey(string.Empty)
                ).ToString().ToLower());

            var errorCrear =
                @Html.Raw((
                    ViewData.ModelState.ContainsKey("Titulo") ||
                    ViewData.ModelState.ContainsKey("Editorial") ||
                    ViewData.ModelState.ContainsKey("Edicion") ||
                    ViewData.ModelState.ContainsKey("AñoPublicacion") ||
                    ViewData.ModelState.ContainsKey("Descripcion") ||
                    ViewData.ModelState.ContainsKey(string.Empty)
                ).ToString().ToLower());

            if (errorCrear) {
                abrirModalCrear();
            }
        });
    </script>
}
}