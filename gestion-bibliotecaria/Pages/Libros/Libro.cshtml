@page "/Libro"
@using System.Data
@model gestion_bibliotecaria.Pages.LibroModel
@{
    ViewData["Title"] = "Gestión de Libros";
}

<h1>📚 Gestión de Libros</h1>

<div class="mb-3">
    <a href="/Libro/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Agregar Nuevo Libro
    </a>
</div>

@if (Model.Libros.Rows.Count == 0)
{
    <div class="alert alert-info">
        No hay libros registrados en el sistema.
    </div>
}
else
{
    var total = Model.Libros.Rows.Count;
    var activos = 0;
    foreach (DataRow row in Model.Libros.Rows)
    {
        if (row.Field<bool>("Estado"))
        {
            activos++;
        }
    }
    var inactivos = total - activos;

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Título</th>
                    <th>Autor</th>
                    <th>Editorial</th>
                    <th>Edición</th>
                    <th>Año</th>
                    <th>Estado</th>
                    <th style="width: 200px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (System.Data.DataRow row in Model.Libros.Rows)
                {
                    var libroId = row.Field<int>("LibroId");
                    var autorId = row.Field<int>("AutorId");
                    var titulo = row.Field<string>("Titulo");
                    var editorial = row.Field<string>("Editorial");
                    var edicion = row.Field<string>("Edicion");
                    var añoPublicacion = row.Field<int?>("AñoPublicacion");
                    var estado = row.Field<bool>("Estado");

                    <tr class="@(!estado ? "table-secondary" : "")">
                        <td>@libroId</td>
                        <td><strong>@titulo</strong></td>
                        <td>
                            @if (Model.AutoresNombres.TryGetValue(autorId, out var nombreAutor))
                            {
                                <span>@nombreAutor</span>
                            }
                            else
                            {
                                <span class="text-muted">Autor #@autorId</span>
                            }
                        </td>
                        <td>@(editorial ?? "N/A")</td>
                        <td>@(edicion ?? "N/A")</td>
                        <td>@(añoPublicacion?.ToString() ?? "N/A")</td>
                        <td>
                            @if (estado)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a href="/Libro/Edit/@libroId"
                                   class="btn btn-sm btn-warning" title="Editar">
                                    ✏️
                                </a>
                                <a href="/Libro/Delete/@libroId"
                                   class="btn btn-sm btn-danger" title="Eliminar">
                                    🗑️
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="row mt-3">
        <div class="col-md-4">
            <div class="alert alert-info">
                <strong>Total libros:</strong> @total
            </div>
        </div>
        <div class="col-md-4">
            <div class="alert alert-success">
                <strong>Activos:</strong> @activos
            </div>
        </div>
        <div class="col-md-4">
            <div class="alert alert-secondary">
                <strong>Inactivos:</strong> @inactivos
            </div>
        </div>
    </div>
}
