@page "/Libro/Delete/{id:int}"
@model gestion_bibliotecaria.Pages.LibroDeleteModel
@{
    ViewData["Title"] = "Eliminar Libro";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/libroDelete.css" />
}

<div class="libro-delete-container">

    <!-- HEADER -->
    <div class="page-header">

        <div class="titulo-logo">
            @* <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" *@
                    <img class="icono-header">

            <h1>Desactivar Libro</h1>
        </div>

    </div>


    <!-- ALERTA -->
    <div class="warning-box">

        <h3>¿Estás seguro de que deseas desactivar este libro?</h3>

        <p>
            Esta acción cambiará el estado del libro a <strong>Inactivo</strong>.
        </p>

    </div>


    <!-- DETALLE DEL LIBRO -->
    <div class="detalle-card">

        <dl class="detalle-grid">

            <dt>ID Libro</dt>
            <dd>@Model.LibroId</dd>

            <dt>Título</dt>
            <dd><strong>@Model.Titulo</strong></dd>

            <dt>Autor</dt>
            <dd>@Model.NombreAutor</dd>

            <dt>Editorial</dt>
            <dd>@(Model.Editorial ?? "N/A")</dd>

            <dt>Edición</dt>
            <dd>@(Model.Edicion ?? "N/A")</dd>

            <dt>Año Publicación</dt>
            <dd>@(Model.AñoPublicacion?.ToString() ?? "N/A")</dd>

            <dt>Descripción</dt>
            <dd>@(Model.Descripcion ?? "N/A")</dd>

            <dt>Estado</dt>
            <dd>
                @if (Model.Estado)
                {
                    <span class="estado activo">Activo</span>
                }
                else
                {
                    <span class="estado inactivo">Inactivo</span>
                }
            </dd>

            <dt>Fecha Registro</dt>
            <dd>@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</dd>

            @if (Model.UltimaActualizacion.HasValue)
            {
                <dt>Última Actualización</dt>
                <dd>@Model.UltimaActualizacion.Value.ToString("dd/MM/yyyy HH:mm")</dd>
            }

        </dl>

    </div>


    <!-- BOTONES -->
    <form method="post" class="form-actions">

        <button type="submit" class="btn-desactivar">

            <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                    class="icono-btn">

            Desactivar Libro

        </button>

        <a href="/Libro" class="btn-cancelar">
            Cancelar
        </a>

    </form>

</div>