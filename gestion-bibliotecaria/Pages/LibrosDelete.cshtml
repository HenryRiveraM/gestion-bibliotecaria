@page "{id:int}"
@model gestion_bibliotecaria.Pages.LibrosDeleteModel
@{
    ViewData["Title"] = "Eliminar Libro";
}

<h1>Eliminar Libro</h1>

<div class="alert alert-warning">
    <h4>¿Estás seguro de que deseas eliminar este libro?</h4>
    <p>Esta acción no se puede deshacer.</p>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID Libro</dt>
            <dd class="col-sm-9">@Model.Libro.LibroId</dd>

            <dt class="col-sm-3">Título</dt>
            <dd class="col-sm-9"><strong>@Model.Libro.Titulo</strong></dd>

            <dt class="col-sm-3">Autor</dt>
            <dd class="col-sm-9">@Model.NombreAutor</dd>

            <dt class="col-sm-3">Editorial</dt>
            <dd class="col-sm-9">@(Model.Libro.Editorial ?? "N/A")</dd>

            <dt class="col-sm-3">Edición</dt>
            <dd class="col-sm-9">@(Model.Libro.Edicion ?? "N/A")</dd>

            <dt class="col-sm-3">Año de Publicación</dt>
            <dd class="col-sm-9">@(Model.Libro.AñoPublicacion?.ToString() ?? "N/A")</dd>

            @if (!string.IsNullOrEmpty(Model.Libro.Descripcion))
            {
                <dt class="col-sm-3">Descripción</dt>
                <dd class="col-sm-9">@Model.Libro.Descripcion</dd>
            }

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">@(Model.Libro.Estado ? "Activo" : "Inactivo")</dd>

            <dt class="col-sm-3">Fecha de Registro</dt>
            <dd class="col-sm-9">@Model.Libro.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</dd>

            @if (Model.Libro.UltimaActualizacion.HasValue)
            {
                <dt class="col-sm-3">Última Actualización</dt>
                <dd class="col-sm-9">@Model.Libro.UltimaActualizacion.Value.ToString("dd/MM/yyyy HH:mm")</dd>
            }
        </dl>
    </div>
</div>

<form method="post" class="mt-3">
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-page="Libros" class="btn btn-secondary">Cancelar</a>
</form>
