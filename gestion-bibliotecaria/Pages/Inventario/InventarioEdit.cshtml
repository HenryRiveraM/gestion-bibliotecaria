@page "/Inventario/Edit/{id:int}"
@model gestion_bibliotecaria.Pages.InventarioEditModel
@{
    ViewData["Title"] = "Editar Ejemplar - Inventario";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/InventarioEdit.css" />
}

<div class="inventario-edit-container">

<div class="page-header">

    <div class="titulo-logo">
        <img@* <img src="~/assets/icons/edit_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" *@
             class="icono-header">
        <h1>Editar Ejemplar</h1>
    </div>

</div>


@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="error-box">@Model.ErrorMessage</div>
}


<div class="form-card">

<form method="post">

<input type="hidden" asp-for="Ejemplar.EjemplarId" />
<input type="hidden" asp-for="Ejemplar.FechaRegistro" />


<div class="form-group">

<label asp-for="Ejemplar.LibroId">Libro</label>

<select asp-for="Ejemplar.LibroId"
        class="input-form"
        required>

<option value="">Seleccione un libro...</option>

@foreach (var libro in Model.Libros)
{
<option value="@libro.LibroId">
@libro.Titulo (@libro.Editorial)
</option>
}

</select>

</div>


<div class="form-group">

<label asp-for="Ejemplar.CodigoInventario">
Código de Inventario
</label>

<input asp-for="Ejemplar.CodigoInventario"
       class="input-form"
       required />

<small class="text-muted">
Debe ser único en el sistema
</small>

</div>


<div class="form-group">

<label asp-for="Ejemplar.EstadoConservacion">
Estado de Conservación
</label>

<select asp-for="Ejemplar.EstadoConservacion"
        class="input-form">

<option value="">Seleccione...</option>
<option value="Excelente">Excelente</option>
<option value="Muy Bueno">Muy Bueno</option>
<option value="Bueno">Bueno</option>
<option value="Regular">Regular</option>
<option value="Malo">Malo</option>

</select>

</div>


<div class="form-group">

<label asp-for="Ejemplar.Ubicacion">
Ubicación
</label>

<input asp-for="Ejemplar.Ubicacion"
       class="input-form" />

</div>


<div class="form-check">

<input asp-for="Ejemplar.Disponible"
       class="check-input"
       type="checkbox" />

<label>
Disponible para préstamo
</label>

</div>


<div class="form-check">

<input asp-for="Ejemplar.DadoDeBaja"
       class="check-input"
       type="checkbox"
       id="dadoBajaCheck" />

<label>
Dado de Baja
</label>

</div>


<div class="form-group"
     id="motivoBajaDiv">

<label asp-for="Ejemplar.MotivoBaja">
Motivo de Baja
</label>

<textarea asp-for="Ejemplar.MotivoBaja"
          class="input-form"
          rows="3">
</textarea>

</div>


<div class="form-check">

<input asp-for="Ejemplar.Estado"
       class="check-input"
       type="checkbox" />

<label>
Activo en el sistema
</label>

</div>


<div class="form-actions">

<button type="submit"
        class="btn-guardar">
Actualizar
</button>

<a href="/Inventario"
   class="btn-cancelar">
Cancelar
</a>

</div>

</form>

</div>

</div>


@section Scripts {

<script>

function toggleMotivoBaja(){

const checkbox = document.getElementById('dadoBajaCheck');
const div = document.getElementById('motivoBajaDiv');

if(!checkbox || !div){
return;
}

div.style.display =
checkbox.checked ? 'block' : 'none';

}

document.getElementById('dadoBajaCheck')
.addEventListener('change', toggleMotivoBaja);

toggleMotivoBaja();

</script>

}