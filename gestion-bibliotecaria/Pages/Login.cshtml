@page "/Login"
@model gestion_bibliotecaria.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="container py-5">
    <h1 class="mb-3">Login</h1>

    @if (!string.IsNullOrWhiteSpace(Model.MensajeError))
    {
        <div class="alert alert-danger" role="alert">
            @Model.MensajeError
        </div>
    }

    <form method="post" class="row g-3" autocomplete="off">
        @Html.AntiForgeryToken()

        <div class="col-12">
            <label class="form-label" for="NombreUsuario">Nombre de usuario</label>
            <input asp-for="NombreUsuario" class="form-control" id="NombreUsuario" required />
        </div>

        <div class="col-12">
            <label class="form-label" for="Password">Contrasena</label>
            <input asp-for="Password" class="form-control" id="Password" type="password" required />
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary">Ingresar</button>
        </div>
    </form>
</div>
