@page
@model gestion_bibliotecaria.Pages.LibrosCreateModel
@{
    ViewData["Title"] = "Nuevo Libro";
}

<h1>Agregar Nuevo Libro</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

<form method="post">
    <div class="mb-3">
        <label asp-for="Libro.AutorId" class="form-label">Autor</label>
        <select asp-for="Libro.AutorId" class="form-control" required>
            <option value="">Seleccione un autor...</option>
            @foreach (var autor in Model.Autores)
            {
                <option value="@autor.AutorId">@autor.Nombres @autor.Apellidos</option>
            }
        </select>
    </div>
    
    <div class="mb-3">
        <label asp-for="Libro.Titulo" class="form-label">Título</label>
        <input asp-for="Libro.Titulo" class="form-control" required 
               placeholder="Ingrese el título del libro" />
    </div>
    
    <div class="mb-3">
        <label asp-for="Libro.Editorial" class="form-label">Editorial</label>
        <input asp-for="Libro.Editorial" class="form-control" 
               placeholder="Ingrese la editorial" />
    </div>
    
    <div class="mb-3">
        <label asp-for="Libro.Edicion" class="form-label">Edición</label>
        <input asp-for="Libro.Edicion" class="form-control" 
               placeholder="Ej: 1ra, 2da, 3ra..." />
    </div>
    
    <div class="mb-3">
        <label asp-for="Libro.AñoPublicacion" class="form-label">Año de Publicación</label>
        <input asp-for="Libro.AñoPublicacion" class="form-control" type="number" 
               min="1000" max="2100" placeholder="Ej: 2024" />
    </div>
    
    <div class="mb-3">
        <label asp-for="Libro.Descripcion" class="form-label">Descripción</label>
        <textarea asp-for="Libro.Descripcion" class="form-control" rows="4" 
                  placeholder="Ingrese una descripción del libro"></textarea>
    </div>
    
    <div class="mb-3">
        <div class="form-check">
            <input asp-for="Libro.Estado" class="form-check-input" type="checkbox" checked />
            <label asp-for="Libro.Estado" class="form-check-label">Activo en el sistema</label>
        </div>
    </div>
    
    <div class="mb-3">
        <button type="submit" class="btn btn-primary">Guardar</button>
        <a asp-page="Libros" class="btn btn-secondary">Cancelar</a>
    </div>
</form>
