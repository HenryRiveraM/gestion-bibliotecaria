@page "/Autor/Edit/{token}"
@model gestion_bibliotecaria.Pages.AutorEditModel
@{
    ViewData["Title"] = "Editar Autor";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/AutorEdit.css" />
}

<div class="autor-edit-container">

    <div class="page-header">

        <div class="titulo-logo">
            @* <img src="~/assets/icons/edit_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" *@
                    <img class="icono-header">
            <h1>Editar Autor</h1>
        </div>

    </div>

    <div class="form-card">

        <form method="post">

            <div asp-validation-summary="ModelOnly" class="error-summary"></div>

            <input type="hidden" asp-for="Autor.AutorId" />
            <input type="hidden" asp-for="AutorToken" />

            <div class="form-group">
                <label>Nombres</label>
                <input asp-for="Autor.Nombres" class="input-form" required />
                <span asp-validation-for="Autor.Nombres" class="text-error"></span>
            </div>

            <div class="form-group">
                <label>Apellidos</label>
        <input asp-for="Autor.Apellidos" class="input-form" />
                <span asp-validation-for="Autor.Apellidos" class="text-error"></span>
            </div>

            <div class="form-group">
                <label>Nacionalidad</label>
                <input asp-for="Autor.Nacionalidad" class="input-form" />
                <span asp-validation-for="Autor.Nacionalidad" class="text-error"></span>
            </div>

            <div class="form-group">
                <label>Fecha de Nacimiento</label>
                <input asp-for="Autor.FechaNacimiento" type="date" class="input-form" />
                <span asp-validation-for="Autor.FechaNacimiento" class="text-error"></span>
            </div>

            <div class="form-check">
                <input asp-for="Autor.Estado" class="check-input" />
                <label>Activo</label>
            </div>

            <div class="form-actions">

                <button type="submit" class="btn-actualizar">
                    Actualizar
                </button>

                <a href="/Autor" class="btn-cancelar">
                    Cancelar
                </a>

            </div>

        </form>

    </div>

</div>