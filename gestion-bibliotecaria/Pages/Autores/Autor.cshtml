@page "/Autor"
@model gestion_bibliotecaria.Pages.AutorModel
@{
    ViewData["Title"] = "Gestión de Autores";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/Autores.css" />
}

<div class="autores-container">

    <div class="page-header">


        <a asp-page="AutorCreate" class="btn-nuevo">
            <img src="~/assets/icons/add_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-btn">
            Nuevo Autor
        </a>

    </div>

    <div class="filtros-barra">
        <div class="filtro-item filtro-buscar">
            <input id="buscador-autor"
                   type="text"
                   class="input-filtro"
                   placeholder="Buscar por nombre, apellido o nacionalidad..."
                   autocomplete="off" />
        </div>
        <div class="filtro-item">
            <select id="orden-autor" class="input-filtro">
                <option value="apellido_asc">Apellidos A-Z</option>
                <option value="nombre_asc">Nombres A-Z</option>
            </select>
        </div>
    </div>

    <div id="tabla-autor" class="tabla-container">

        <table class="tabla-autores">

            <thead>
                <tr>
                    <th>
                        <img src="~/assets/icons/person_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-header">
                        Nombres
                    </th>
                    <th>Apellidos</th>
                    <th>Nacionalidad</th>
                    <th>Fecha Nacimiento</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>

                @foreach (System.Data.DataRow row in Model.AutorDataTable.Rows)
                {
                    <tr>

                        <td>@row["Nombres"]</td>
                        <td>@row["Apellidos"]</td>
                        <td>@row["Nacionalidad"]</td>
                        <td>@(row.IsNull("FechaNacimiento") ? string.Empty : ((DateTime)row["FechaNacimiento"]).ToString("yyyy-MM-dd"))</td>

                        <td>
                            @if ((bool)row["Estado"])
                            {
                                <span class="estado activo">Activo</span>
                            }
                            else
                            {
                                <span class="estado inactivo">Inactivo</span>
                            }
                        </td>

                        <td class="acciones">

                            <a asp-page="AutorEdit"
                                asp-route-id="@row["AutorId"]"
                                class="btn-editar">

                                <img src="~/assets/icons/edit_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                        class="icono-btn">

                                Editar
                            </a>

                            <a asp-page="AutorDelete"
                                asp-route-id="@row["AutorId"]"
                                class="btn-eliminar">

                                <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                        class="icono-btn">

                                Eliminar
                            </a>

                        </td>

                    </tr>
                }
                    <tr id="fila-sin-resultados" style="display:none;">
                        <td colspan="6" style="text-align:center; padding:20px; color:#9ca3af;">
                            No hay autores que coincidan con la búsqueda.
                        </td>
                    </tr>
            </tbody>

        </table>

    </div>

</div>


@section Scripts {
    <script>
        (function () {

            var input = document.getElementById('buscador-autor');
            var select = document.getElementById('orden-autor');
            var tabla = document.getElementById('tabla-autor');

            if (!input || !tabla) return;

            function normalizar(s) {
                return (s || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim();
            }

            function aplicar() {

                var termino = normalizar(input.value);
                var orden = select ? select.value : 'apellido_asc';

                var tbody = tabla.querySelector('tbody');
                var filas = Array.from(tbody.querySelectorAll('tr:not(#fila-sin-resultados)'));

                // ORDENAR
                var colIndex = orden.startsWith('apellido') ? 1 : 0;

                filas.sort(function (a, b) {
                    var va = normalizar(a.cells[colIndex] ? a.cells[colIndex].textContent : '');
                    var vb = normalizar(b.cells[colIndex] ? b.cells[colIndex].textContent : '');
                    return va.localeCompare(vb);
                });

                filas.forEach(function (f) { tbody.appendChild(f); });

                // FILTRAR
                var visibles = 0;

                filas.forEach(function (fila) {
                    var texto = normalizar(fila.textContent);
                    var coincide = termino === '' || texto.includes(termino);
                    fila.style.display = coincide ? '' : 'none';
                    if (coincide) visibles++;
                });

                var sinResultados = document.getElementById('fila-sin-resultados');

                if (sinResultados) {
                    sinResultados.style.display = visibles === 0 ? '' : 'none';
                    tbody.appendChild(sinResultados);
                }

            }

            input.addEventListener('input', aplicar);
            if (select) select.addEventListener('change', aplicar);

            aplicar();

        })();
    </script>
}