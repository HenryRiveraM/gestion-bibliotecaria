@page "/Autor"
@model gestion_bibliotecaria.Pages.AutorModel
@{
    ViewData["Title"] = "Gestión de Autores";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/Autores.css" />
}

<div class="autores-container">

    <div class="page-header">

        <div class="titulo-logo">
            <h1>Gestión de Autores</h1>
        </div>

        <a asp-page="AutorCreate" class="btn-nuevo">
            <img src="~/assets/icons/add_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-btn">
            Nuevo Autor
        </a>

    </div>

    <div class="filtros-barra">
        <div class="filtro-item filtro-buscar">
            <input id="buscador-autor"
                   type="text"
                   class="input-filtro"
                   placeholder="Buscar por nombres, apellidos, nacionalidad o estado..."
                   autocomplete="off" />
        </div>
    </div>

    <div id="tabla-autor" class="tabla-container">

        <table id="tabla-autores" class="tabla-autores">

            <thead>
                <tr>
                    <th>Nombres</th>
                    <th>Apellidos</th>
                    <th>Nacionalidad</th>
                    <th>Fecha Nacimiento</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>

                @foreach (System.Data.DataRow row in Model.AutorDataTable.Rows)
                {
                    <tr>

                        <td>@row["Nombres"]</td>
                        <td>@row["Apellidos"]</td>
                        <td>@row["Nacionalidad"]</td>
                        <td>@(row.IsNull("FechaNacimiento") ? "" : ((DateTime)row["FechaNacimiento"]).ToString("yyyy-MM-dd"))</td>

                        <td>
                            @if ((bool)row["Estado"])
                            {
                                <span class="estado activo">Activo</span>
                            }
                            else
                            {
                                <span class="estado inactivo">Inactivo</span>
                            }
                        </td>

                        <td class="acciones">

                            <a asp-page="AutorEdit"
                                asp-route-token="@row["AutorToken"]"
                                    class="btn-editar">

                                <img src="~/assets/icons/edit_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                class="icono-btn">

                                Editar
                            </a>

                        <!-- BOTON MODAL ELIMINAR -->
                            <button class="btn-eliminar"
                                onclick="abrirModal('@row["AutorToken"]')">

                                <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                    class="icono-btn">

                                Eliminar
                            </button>

                        </td>

                    </tr>
                }

                <tr id="fila-sin-resultados" style="display:none;">
                    <td colspan="6" style="text-align:center; padding:20px; color:#9ca3af;">
                        No hay autores que coincidan con la búsqueda.
                    </td>
                </tr>

            </tbody>

        </table>

    </div>

</div>

<!-- Modal eliminar -->
<div id="modalEliminar" class="modal">

    <div class="modal-box">

        <div class="modal-icon">
            <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                class="icono-modal">
        </div>

        <h2>¿Estás seguro de que quieres eliminar este autor?</h2>

        <p>Esta acción no se puede deshacer.</p>

        <div class="modal-buttons">

            <a id="btnConfirmarEliminar" class="btn-danger">
                Sí, eliminar
            </a>

            <button class="btn-secondary" onclick="cerrarModal()">
                Cancelar
            </button>

        </div>

    </div>

</div>

@section Scripts {
    <script>
        (function () {
            var input = document.getElementById('buscador-autor');
            var tabla = document.getElementById('tabla-autores');

            if (!input || !tabla) return;

            function normalizar(s) {
                return (s || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim();
            }

            function aplicarBusqueda() {
                var termino = normalizar(input.value);
                var tbody = tabla.querySelector('tbody');
                var filas = Array.from(tbody.querySelectorAll('tr:not(#fila-sin-resultados)'));

                var visibles = 0;

                filas.forEach(function (fila) {
                    var texto = normalizar(fila.textContent);
                    var coincide = termino === '' || texto.includes(termino);
                    fila.style.display = coincide ? '' : 'none';
                    if (coincide) visibles++;
                });

                var sinResultados = document.getElementById('fila-sin-resultados');
                if (sinResultados) {
                    sinResultados.style.display = visibles === 0 ? '' : 'none';
                    tbody.appendChild(sinResultados);
                }
            }

            input.addEventListener('input', aplicarBusqueda);
            aplicarBusqueda();
        })();

        function abrirModal(token) {
            var url = "/Autor/Delete/" + token;
            document.getElementById("btnConfirmarEliminar").href = url;
            document.getElementById("modalEliminar").style.display = "flex";
        }

        function cerrarModal() {
            document.getElementById("modalEliminar").style.display = "none";
        }
    </script>
}