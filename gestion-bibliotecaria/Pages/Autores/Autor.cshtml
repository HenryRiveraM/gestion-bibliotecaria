@page "/Autor"
@using System.Linq
@model gestion_bibliotecaria.Pages.AutorModel
@{
    ViewData["Title"] = "Gestión de Autores";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/Autores.css" />
}

<div class="autores-container">

    <div class="page-header">
        <div class="titulo-logo">
            <h1>Gestión de Autores</h1>
        </div>

        <button type="button" class="btn-nuevo" onclick="abrirModalCrear()">
            <img src="~/assets/icons/add_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-btn">
            Nuevo Autor
        </button>
    </div>

    <div class="filtros-barra">
        <div class="filtro-item filtro-buscar">
            <input id="buscador-autor"
                   type="text"
                   class="input-filtro"
                   placeholder="Buscar..."
                   autocomplete="off" />
        </div>
    </div>

    <div class="tabla-container">

        <table id="tabla-autores" class="tabla-autores">
            <thead>
                <tr>
                    <th>Nombres</th>
                    <th>Apellidos</th>
                    <th>Nacionalidad</th>
                    <th>Fecha</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (System.Data.DataRow row in Model.AutorDataTable.Rows)
                {
                    var token = row["AutorToken"]?.ToString() ?? "";
                    var nombres = row["Nombres"]?.ToString() ?? "";
                    var apellidos = row["Apellidos"]?.ToString() ?? "";
                    var nacionalidad = row["Nacionalidad"]?.ToString() ?? "";
                    var fecha = row.IsNull("FechaNacimiento")
                        ? ""
                        : ((DateTime)row["FechaNacimiento"]).ToString("yyyy-MM-dd");
                    var estado = (bool)row["Estado"];

                    <tr>
                        <td>@nombres</td>
                        <td>@apellidos</td>
                        <td>@nacionalidad</td>
                        <td>@(row.IsNull("FechaNacimiento") ? "" : ((DateTime)row["FechaNacimiento"]).ToString("yyyy-MM-dd"))</td>

                        <td>
                            @if (estado)
                            {
                                <span class="estado activo">Activo</span>
                            }
                            else
                            {
                                <span class="estado inactivo">Inactivo</span>
                            }
                        </td>

                        <td class="acciones">
                            <button type="button"
                                    class="btn-editar"
                                    onclick="abrirModalEditar(
                                        '@token',
                                        '@Html.Raw(nombres.Replace("'", "\\'"))',
                                        '@Html.Raw(apellidos.Replace("'", "\\'"))',
                                        '@Html.Raw(nacionalidad.Replace("'", "\\'"))',
                                        '@fecha',
                                        '@(estado.ToString().ToLower())'
                                    )">
                                <img src="~/assets/icons/edit_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                     class="icono-btn">
                                Editar
                            </button>

                            <button type="button"
                                    class="btn-eliminar"
                                    onclick="abrirModal('@token')">
                                <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                     class="icono-btn">
                                Eliminar
                            </button>
                        </td>
                    </tr>
                }

                <tr id="fila-sin-resultados" style="display:none;">
                    <td colspan="6" style="text-align:center; padding:20px; color:#9ca3af;">
                        No hay autores que coincidan con la búsqueda.
                    </td>
                </tr>
            </tbody>
        </table>

    </div>
</div>

<!-- MODAL ELIMINAR -->
<div id="modalEliminar" class="modal">
    <div class="modal-box">

        <div class="modal-icon">
            <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                 class="icono-modal">
        </div>

        <h2>¿Eliminar autor?</h2>
        <p>No se puede deshacer.</p>

        <form method="post" asp-page-handler="Eliminar">
            @Html.AntiForgeryToken()

            <input type="hidden" id="autorTokenInput" name="token" />

            <div class="modal-buttons">
                <button type="submit" class="btn-danger">Eliminar</button>
                <button type="button" class="btn-secondary" onclick="cerrarModal()">Cancelar</button>
            </div>
        </form>

    </div>
</div>

<!-- MODAL EDITAR -->
<div id="modalEditar" class="modal">
    <div class="modal-box">

        <div class="modal-icon editar">
            <img src="~/assets/icons/edit_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                 class="icono-modal">
        </div>

        <h2>Editar Autor</h2>
        <p>Modifica la información del autor.</p>

        <form method="post" asp-page-handler="Editar" id="editAutorForm">
            @Html.AntiForgeryToken()

            <input type="hidden" id="editToken" name="token" value="@Model.EditToken" />

            <input type="text"
                   id="editNombres"
                   name="Nombres"
                   placeholder="Nombres"
                   required
                   value="@Model.EditNombres" />
            @if (ViewData.ModelState.ContainsKey("Nombres"))
            {
                <span class="text-error">@ViewData.ModelState["Nombres"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
            }

            <input type="text"
                   id="editApellidos"
                   name="Apellidos"
                   placeholder="Apellidos"
                   value="@Model.EditApellidos" />
            @if (ViewData.ModelState.ContainsKey("Apellidos"))
            {
                <span class="text-error">@ViewData.ModelState["Apellidos"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
            }

            <div class="custom-select-wrapper">
                <input type="hidden"
                       id="editNacionalidadValue"
                       name="Nacionalidad"
                       value="@Model.EditNacionalidad" />

                <div class="custom-select" id="custom-select-nacionalidad-edit">
                    <div class="select-trigger">
                        <span id="editNacionalidadText">
                            @(string.IsNullOrWhiteSpace(Model.EditNacionalidad) ? "-- Seleccione una nacionalidad --" : Model.EditNacionalidad)
                        </span>
                        <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>

                    <div class="select-dropdown">
                        <input type="text"
                               class="select-search"
                               id="editNacionalidadSearch"
                               placeholder="Buscar nacionalidad..." />

                        <div class="select-options">
                            <div class="option" data-value="Boliviana">Boliviana</div>
                            <div class="option" data-value="Argentina">Argentina</div>
                            <div class="option" data-value="Brasileña">Brasileña</div>
                            <div class="option" data-value="Chilena">Chilena</div>
                            <div class="option" data-value="Colombiana">Colombiana</div>
                            <div class="option" data-value="Ecuatoriana">Ecuatoriana</div>
                            <div class="option" data-value="Paraguaya">Paraguaya</div>
                            <div class="option" data-value="Peruana">Peruana</div>
                            <div class="option" data-value="Uruguaya">Uruguaya</div>
                            <div class="option" data-value="Venezolana">Venezolana</div>
                            <div class="option" data-value="Mexicana">Mexicana</div>
                            <div class="option" data-value="Estadounidense">Estadounidense</div>
                            <div class="option" data-value="Canadiense">Canadiense</div>
                            <div class="option" data-value="Española">Española</div>
                            <div class="option" data-value="Francesa">Francesa</div>
                            <div class="option" data-value="Alemana">Alemana</div>
                            <div class="option" data-value="Italiana">Italiana</div>
                            <div class="option" data-value="Portuguesa">Portuguesa</div>
                            <div class="option" data-value="Británica">Británica</div>
                            <div class="option" data-value="Japonesa">Japonesa</div>
                            <div class="option" data-value="China">China</div>
                            <div class="option" data-value="Coreana">Coreana</div>
                            <div class="option" data-value="India">India</div>
                            <div class="option" data-value="Otra">Otra</div>
                        </div>
                    </div>
                </div>
            </div>
            @if (ViewData.ModelState.ContainsKey("Nacionalidad"))
            {
                <span class="text-error">@ViewData.ModelState["Nacionalidad"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
            }

            <input type="date"
                   id="editFechaNacimiento"
                   name="FechaNacimiento"
                   value="@(Model.EditFechaNacimiento?.ToString("yyyy-MM-dd"))" />
            @if (ViewData.ModelState.ContainsKey("FechaNacimiento"))
            {
                <span class="text-error">@ViewData.ModelState["FechaNacimiento"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
            }

            <input type="hidden"
                   id="editEstadoHidden"
                   name="Estado"
                   value="@(Model.EditEstado.ToString().ToLower())" />

            <select id="editEstado">
                <option value="true" selected="@(Model.EditEstado ? "selected" : null)">Activo</option>
                <option value="false" selected="@(!Model.EditEstado ? "selected" : null)">Inactivo</option>
            </select>

            <div class="modal-buttons">
                <button type="submit" class="btn-warning">Guardar</button>
                <button type="button" class="btn-secondary" onclick="cerrarModalEditar()">Cancelar</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL CREAR -->
<div id="modalCrear" class="modal">
    <div class="modal-box">

        <div class="modal-icon crear">
            <img src="~/assets/icons/add_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                 class="icono-modal">
        </div>

        <h2>Nuevo Autor</h2>
        <p>Ingresa los datos del autor</p>

        <form method="post" asp-page-handler="Crear">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-error-summary"></div>

            <input type="text"
                   name="Autor.Nombres"
                   id="createNombres"
                   placeholder="Nombres"
                   required
                   value="@Model.Autor.Nombres" />
            @if (ViewData.ModelState.ContainsKey("Autor.Nombres"))
            {
                <span class="text-error">@ViewData.ModelState["Autor.Nombres"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
            }

            <input type="text"
                   name="Autor.Apellidos"
                   id="createApellidos"
                   placeholder="Apellidos"
                   value="@Model.Autor.Apellidos" />
            @if (ViewData.ModelState.ContainsKey("Autor.Apellidos"))
            {
                <span class="text-error">@ViewData.ModelState["Autor.Apellidos"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
            }

            <div class="custom-select-wrapper">
                <input type="hidden"
                       id="nacionalidad-value-modal"
                       name="Autor.Nacionalidad"
                       value="@Model.Autor.Nacionalidad" />

                <div class="custom-select" id="custom-select-nacionalidad-modal">
                    <div class="select-trigger">
                        <span id="nacionalidad-text-modal">
                            @(string.IsNullOrWhiteSpace(Model.Autor.Nacionalidad) ? "-- Seleccione una nacionalidad --" : Model.Autor.Nacionalidad)
                        </span>
                        <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>

                    <div class="select-dropdown">
                        <input type="text"
                               class="select-search"
                               id="nacionalidad-search-modal"
                               placeholder="Buscar nacionalidad..." />

                        <div class="select-options">
                            <div class="option" data-value="Boliviana">Boliviana</div>
                            <div class="option" data-value="Argentina">Argentina</div>
                            <div class="option" data-value="Brasileña">Brasileña</div>
                            <div class="option" data-value="Chilena">Chilena</div>
                            <div class="option" data-value="Colombiana">Colombiana</div>
                            <div class="option" data-value="Peruana">Peruana</div>
                            <div class="option" data-value="Mexicana">Mexicana</div>
                            <div class="option" data-value="Española">Española</div>
                            <div class="option" data-value="Otra">Otra</div>
                        </div>
                    </div>
                </div>
            </div>
            @if (ViewData.ModelState.ContainsKey("Autor.Nacionalidad"))
            {
                <span class="text-error">@ViewData.ModelState["Autor.Nacionalidad"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
            }

            <input type="date"
                   id="createFechaNacimiento"
                   name="Autor.FechaNacimiento"
                   value="@(Model.Autor.FechaNacimiento?.ToString("yyyy-MM-dd"))" />
            @if (ViewData.ModelState.ContainsKey("Autor.FechaNacimiento"))
            {
                <span class="text-error">@ViewData.ModelState["Autor.FechaNacimiento"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
            }

            <select name="Autor.Estado" id="createEstado">
                <option value="true" selected="@(Model.Autor.Estado ? "selected" : null)">Activo</option>
                <option value="false" selected="@(!Model.Autor.Estado ? "selected" : null)">Inactivo</option>
            </select>

            <div class="modal-buttons">
                <button type="submit" class="btn-success">Crear</button>
                <button type="button" class="btn-secondary" onclick="cerrarModalCrear()">Cancelar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var input = document.getElementById('buscador-autor');
    var tabla = document.getElementById('tabla-autores');

    if (!input || !tabla) return;

    input.addEventListener('input', function () {
        var filtro = input.value.toLowerCase();
        var filas = tabla.querySelectorAll('tbody tr');

        filas.forEach(f => {
            f.style.display = f.textContent.toLowerCase().includes(filtro) ? "" : "none";
        });
    });
})();

function abrirModal(token) {
    document.getElementById("autorTokenInput").value = token;
    document.getElementById("modalEliminar").style.display = "flex";
}

function cerrarModal() {
    document.getElementById("modalEliminar").style.display = "none";
}

function abrirModalEditar(token, nombres, apellidos, nacionalidad, fecha, estado) {
    document.getElementById("editToken").value = token;
    document.getElementById("editNombres").value = nombres || "";
    document.getElementById("editApellidos").value = apellidos || "";
    document.getElementById("editFechaNacimiento").value = fecha || "";
    // SIEMPRE setear el valor desde el botón (el JS manda en este caso)
    document.getElementById("editEstado").value = (estado === "true") ? "true" : "false";
    document.getElementById("editEstadoHidden").value = document.getElementById("editEstado").value;

    document.getElementById("editNacionalidadValue").value = nacionalidad || "";
    document.getElementById("editNacionalidadText").textContent =
        nacionalidad && nacionalidad.trim() !== "" ? nacionalidad : "-- Seleccione una nacionalidad --";

    document.getElementById("modalEditar").style.display = "flex";
}

function cerrarModalEditar() {
    document.getElementById("modalEditar").style.display = "none";
}

function abrirModalCrear() {
    document.getElementById("modalCrear").style.display = "flex";
}

function cerrarModalCrear() {
    document.getElementById("modalCrear").style.display = "none";
}

function initCustomSelect(selectId, searchId, hiddenId, textId) {
    const customSelect = document.getElementById(selectId);
    if (!customSelect) return;

    const trigger = customSelect.querySelector('.select-trigger');
    const search = document.getElementById(searchId);
    const options = customSelect.querySelectorAll('.option');
    const hiddenInput = document.getElementById(hiddenId);
    const selectText = document.getElementById(textId);
    let isOpen = false;

    function applyManualValue() {
        const customValue = search.value.trim();
        if (!customValue) return;
        hiddenInput.value = customValue;
        selectText.textContent = customValue;
    }

    trigger.addEventListener('click', function (e) {
        e.stopPropagation();
        isOpen = !isOpen;
        customSelect.classList.toggle('active', isOpen);

        if (isOpen) {
            search.focus();
            search.value = '';
            options.forEach(opt => opt.classList.remove('hidden'));
        }
    });

    document.addEventListener('click', function (e) {
        if (!customSelect.contains(e.target)) {
            if (isOpen) {
                applyManualValue();
            }
            isOpen = false;
            customSelect.classList.remove('active');
        }
    });

    search.addEventListener('input', function () {
        const term = this.value.toLowerCase();
        options.forEach(option => {
            const text = option.textContent.toLowerCase();
            option.classList.toggle('hidden', !text.includes(term));
        });
    });

    options.forEach(option => {
        option.addEventListener('click', function (e) {
            e.stopPropagation();
            hiddenInput.value = this.dataset.value;
            selectText.textContent = this.textContent.trim();
            isOpen = false;
            customSelect.classList.remove('active');
        });
    });
}

document.addEventListener('DOMContentLoaded', function () {
    initCustomSelect(
        'custom-select-nacionalidad-modal',
        'nacionalidad-search-modal',
        'nacionalidad-value-modal',
        'nacionalidad-text-modal'
    );

    initCustomSelect(
        'custom-select-nacionalidad-edit',
        'editNacionalidadSearch',
        'editNacionalidadValue',
        'editNacionalidadText'
    );

    const editEstadoSelect = document.getElementById("editEstado");
    const editEstadoHidden = document.getElementById("editEstadoHidden");
    const editAutorForm = document.getElementById("editAutorForm");

    if (editEstadoSelect && editEstadoHidden) {
        editEstadoSelect.addEventListener("change", function () {
            editEstadoHidden.value = editEstadoSelect.value;
        });
    }

    if (editAutorForm && editEstadoSelect && editEstadoHidden) {
        editAutorForm.addEventListener("submit", function () {
            editEstadoHidden.value = editEstadoSelect.value;
        });
    }
});

window.onclick = function (e) {
    let m1 = document.getElementById("modalEliminar");
    let m2 = document.getElementById("modalEditar");
    let m3 = document.getElementById("modalCrear");

    if (e.target === m1) cerrarModal();
    if (e.target === m2) cerrarModalEditar();
    if (e.target === m3) cerrarModalCrear();
}
</script>

@if (!ViewData.ModelState.IsValid)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var modalActivo = '@Model.ModalActivo';

            if (modalActivo === "crear") {
                abrirModalCrear();
            }

            if (modalActivo === "editar") {
                document.getElementById("editEstado").value = '@(Model.EditEstado.ToString().ToLower())';
                document.getElementById("editEstadoHidden").value = '@(Model.EditEstado.ToString().ToLower())';
                document.getElementById("modalEditar").style.display = "flex";
            }
        });
    </script>
}
}