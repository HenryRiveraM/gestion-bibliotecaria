@page "/Ejemplar/Delete/{id:int}"
@model gestion_bibliotecaria.Pages.EjemplarDeleteModel
@{
    ViewData["Title"] = "Eliminar Ejemplar";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/EjemplarDelete.css" />
}

<div class="ejemplar-delete-container">

    <div class="page-header">

        <div class="titulo-logo">
            @* <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" *@
                 <img class="icono-header">
            <h1>Eliminar Ejemplar</h1>
        </div>

    </div>


<div class="warning-box">

    <h3>¿Estás seguro de eliminar este ejemplar?</h3>

    <p>
        Esta accion eliminara el ejemplar permanentemente.
    </p>

</div>


@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="error-box">@Model.ErrorMessage</div>
}


<div class="detalle-card">

<dl class="detalle-grid">

    <dt>ID Ejemplar</dt>
    <dd>@Model.Ejemplar.EjemplarId</dd>

    <dt>Codigo Ejemplar</dt>
    <dd><strong>@Model.Ejemplar.CodigoInventario</strong></dd>

    <dt>Libro</dt>
    <dd>@Model.TituloLibro</dd>

    <dt>Estado Conservación</dt>
    <dd>@(Model.Ejemplar.EstadoConservacion ?? "N/A")</dd>

    <dt>Ubicación</dt>
    <dd>@(Model.Ejemplar.Ubicacion ?? "N/A")</dd>

    <dt>Disponible</dt>
    <dd>
        @if (Model.Ejemplar.Disponible)
        {
            <span class="estado activo">Sí</span>
        }
        else
        {
            <span class="estado advertencia">No</span>
        }
    </dd>

    <dt>Dado de Baja</dt>
    <dd>

        @if (Model.Ejemplar.DadoDeBaja)
        {
            <span class="estado baja">Sí</span>

            @if (!string.IsNullOrEmpty(Model.Ejemplar.MotivoBaja))
            {
                <br/>
                <small class="text-muted">
                    Motivo: @Model.Ejemplar.MotivoBaja
                </small>
            }
        }
        else
        {
            <span class="estado neutro">No</span>
        }

    </dd>

    <dt>Estado</dt>
    <dd>
        @if (Model.Ejemplar.Estado)
        {
            <span class="estado activo">Activo</span>
        }
        else
        {
            <span class="estado inactivo">Inactivo</span>
        }
    </dd>

    <dt>Fecha Registro</dt>
    <dd>@Model.Ejemplar.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</dd>

@if (Model.Ejemplar.UltimaActualizacion.HasValue)
{
    <dt>Última Actualización</dt>
    <dd>@Model.Ejemplar.UltimaActualizacion.Value.ToString("dd/MM/yyyy HH:mm")</dd>
}

</dl>

</div>


<form method="post" class="form-actions">

<button type="submit" class="btn-eliminar">

    <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
         class="icono-btn">

    Eliminar Ejemplar

</button>

<a href="/Ejemplar" class="btn-cancelar">
Cancelar
</a>

</form>

</div>