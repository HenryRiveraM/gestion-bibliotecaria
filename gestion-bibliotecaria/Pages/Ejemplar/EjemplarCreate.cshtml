@page "/Ejemplar/Create"
@model gestion_bibliotecaria.Pages.EjemplarCreateModel
@{
    ViewData["Title"] = "Nuevo Ejemplar";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/EjemplarCreate.css" />
}

<div class="ejemplar-create-container">

    <div class="page-header">

        <div class="titulo-logo">
            @* <img src="~/assets/icons/inventory_2_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" *@
                 <img class="icono-header">
            <h1>Nuevo Ejemplar</h1>
        </div>

    </div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="error-box">@Model.ErrorMessage</div>
}

<div class="form-card">

<form method="post">

    <div class="form-group">
        <label asp-for="Ejemplar.LibroId">Libro</label>

        <input type="hidden" asp-for="Ejemplar.LibroId" id="libroIdHidden" />

        <div class="libro-search-wrapper">
            <input type="text"
                   id="buscar-libro"
                   class="input-form"
                   placeholder="Escribe para buscar un libro..."
                   autocomplete="off" />

            <ul id="lista-libros" class="libro-dropdown" style="display:none;">
                @foreach (var libro in Model.Libros)
                {
                    <li class="libro-opcion"
                        data-id="@libro.LibroId"
                        data-texto="@libro.Titulo (@libro.Editorial)">
                        @libro.Titulo <span class="libro-editorial">(@libro.Editorial)</span>
                    </li>
                }
            </ul>
        </div>

        <small class="text-muted" id="libro-seleccionado-texto"></small>

    </div>


    <div class="form-group">

        <label asp-for="Ejemplar.CodigoInventario">
            Codigo de Ejemplar
        </label>

        <input asp-for="Ejemplar.CodigoInventario"
               class="input-form"
               placeholder="Ej: INV-001-2026"
               required />

        <span asp-validation-for="Ejemplar.CodigoInventario" class="text-danger"></span>

        <small class="text-muted">
            Debe ser único en el sistema
        </small>

    </div>


    <div class="form-group">

        <label asp-for="Ejemplar.EstadoConservacion">
            Estado de Conservación
        </label>

        <select asp-for="Ejemplar.EstadoConservacion"
                class="input-form">

            <option value="">Seleccione...</option>
            <option value="Excelente">Excelente</option>
            <option value="Muy Bueno">Muy Bueno</option>
            <option value="Bueno">Bueno</option>
            <option value="Regular">Regular</option>
            <option value="Malo">Malo</option>

        </select>

        <span asp-validation-for="Ejemplar.EstadoConservacion" class="text-danger"></span>

    </div>


<div class="form-group">

    <label asp-for="Ejemplar.Ubicacion">Ubicación</label>

    <div class="custom-select-wrapper">
        <input type="hidden" asp-for="Ejemplar.Ubicacion" id="ubicacion-value" />

        <div class="custom-select" id="custom-select-ubicacion">

            <div class="select-trigger">
                <span id="ubicacion-text">-- Seleccione una ubicación --</span>
                <svg class="select-arrow" viewBox="0 0 24 24">
                    <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
            </div>

            <div class="select-dropdown">

                <input type="text"
                       class="select-search"
                       id="ubicacion-search"
                       placeholder="Buscar ubicación..." />

               <div class="select-options">

                    <div class="option" data-value="Estantería A1">A1</div>
                    <div class="option" data-value="Estantería A2">A2</div>
                    <div class="option" data-value="Estantería A3">A3</div>

                    <div class="option" data-value="Estantería B1">B1</div>
                    <div class="option" data-value="Estantería B2">B2</div>
                    <div class="option" data-value="Estantería B3">B3</div>

                    <div class="option" data-value="Estantería C1">C1</div>
                    <div class="option" data-value="Estantería C2">C2</div>
                    <div class="option" data-value="Estantería C3">C3</div>

                </div>

            </div>
        </div>
    </div>

</div>


    <div class="form-check">

        <input asp-for="Ejemplar.Disponible"
               class="check-input"
               type="checkbox"
               checked />

        <label>
            Disponible para préstamo
        </label>

    </div>


    <div class="form-check">

        <input asp-for="Ejemplar.DadoDeBaja"
               class="check-input"
               type="checkbox"
               id="dadoBajaCheck" />

        <label>
            Dado de Baja
        </label>

    </div>


    <div class="form-group"
         id="motivoBajaDiv"
         style="display:none;">

        <label asp-for="Ejemplar.MotivoBaja">
            Motivo de Baja
        </label>

        <textarea asp-for="Ejemplar.MotivoBaja"
                  class="input-form"
                  rows="3">
        </textarea>

        <span asp-validation-for="Ejemplar.MotivoBaja" class="text-danger"></span>

    </div>


    <div class="form-check">

        <input asp-for="Ejemplar.Estado"
               class="check-input"
               type="checkbox"
               checked />

        <label>
            Activo en el sistema
        </label>

    </div>


    <div class="form-actions">

        <button type="submit"
                class="btn-guardar">
            Guardar
        </button>

        <a href="/Ejemplar"
           class="btn-cancelar">
            Cancelar
        </a>

    </div>

</form>

</div>

</div>


@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const custom = document.getElementById("custom-select-ubicacion");
            const trigger = custom.querySelector(".select-trigger");
            const dropdown = custom.querySelector(".select-dropdown");
            const options = custom.querySelectorAll(".option");
            const search = document.getElementById("ubicacion-search");
            const hidden = document.getElementById("ubicacion-value");
            const text = document.getElementById("ubicacion-text");

            if (!custom || !trigger) return;

            // 🔹 ABRIR / CERRAR
            trigger.addEventListener("click", () => {
                custom.classList.toggle("active");

                if (custom.classList.contains("active")) {
                    search.focus();
                }
            });

            // 🔹 SELECCIONAR OPCIÓN
            options.forEach(option => {
                option.addEventListener("click", () => {
                    const value = option.getAttribute("data-value");

                    hidden.value = value;
                    text.textContent = value;

                    custom.classList.remove("active");
                    search.value = "";

                    // mostrar todas otra vez
                    options.forEach(o => o.style.display = "");
                });
            });

            // 🔹 BUSCAR / FILTRAR
            search.addEventListener("input", () => {
                const filtro = search.value.toLowerCase().trim();

                options.forEach(option => {
                    const texto = option.textContent.toLowerCase();
                    option.style.display = texto.includes(filtro) ? "" : "none";
                });
            });

            // 🔹 CERRAR SI HACES CLICK FUERA
            document.addEventListener("click", (e) => {
                if (!custom.contains(e.target)) {
                    custom.classList.remove("active");
                }
            });

        });
    </script>

<script>

// --- Buscador de libros ---
(function () {
    var input = document.getElementById('buscar-libro');
    var lista = document.getElementById('lista-libros');
    var hidden = document.getElementById('libroIdHidden');
    var textoSel = document.getElementById('libro-seleccionado-texto');
    var opciones = lista ? Array.from(lista.querySelectorAll('.libro-opcion')) : [];

    if (!input || !lista) return;

    function normalizar(s) {
        return (s || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim();
    }

    function mostrar() {
        var termino = normalizar(input.value);
        var visibles = 0;
        opciones.forEach(function (li) {
            var coincide = termino === '' || normalizar(li.dataset.texto).includes(termino);
            li.style.display = coincide ? '' : 'none';
            if (coincide) visibles++;
        });
        lista.style.display = visibles > 0 ? '' : 'none';
    }

    function seleccionar(li) {
        hidden.value = li.dataset.id;
        input.value = li.dataset.texto;
        textoSel.textContent = '';
        lista.style.display = 'none';
    }

    input.addEventListener('input', mostrar);

    input.addEventListener('focus', function () {
        if (input.value.trim() === '') mostrar();
    });

    opciones.forEach(function (li) {
        li.addEventListener('mousedown', function (e) {
            e.preventDefault();
            seleccionar(li);
        });
    });

    document.addEventListener('click', function (e) {
        if (!input.contains(e.target) && !lista.contains(e.target)) {
            lista.style.display = 'none';
        }
    });
})();

// --- Motivo de baja ---
const checkBaja = document.getElementById('dadoBajaCheck');
const motivoBaja = document.getElementById('motivoBajaDiv');

if (checkBaja && motivoBaja) {

    checkBaja.addEventListener('change', function () {

        motivoBaja.style.display =
            this.checked ? 'block' : 'none';

    });

}

</script>
}