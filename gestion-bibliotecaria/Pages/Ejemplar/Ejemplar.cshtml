@page "/Ejemplar"
@model gestion_bibliotecaria.Pages.EjemplarModel
@{
    ViewData["Title"] = "Gestion de Ejemplares";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/ejemplar.css" />
}

<div class="ejemplar-container">

    <div class="page-header">

        <div class="titulo-logo">
            @* <img src="~/assets/icons/inventory_2_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-header"> *@
            <h1>Gestion de Ejemplares</h1>
        </div>

        <a href="/Ejemplar/Create" class="btn-nuevo">
            <img src="~/assets/icons/add_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg" class="icono-btn">
            Nuevo Ejemplar
        </a>

    </div>

    <div class="filtros-barra">
        <div class="filtro-item filtro-buscar">
            <input id="buscador-ejemplar"
                   type="text"
                   class="input-filtro"
                   placeholder="Buscar por codigo, libro, ubicacion o estado..."
                   autocomplete="off" />
        </div>
        <div class="filtro-item">
            <select id="orden-ejemplar" class="input-filtro">
                <option value="codigo_asc">Codigo A-Z</option>
                <option value="titulo_asc">Libro A-Z</option>
            </select>
        </div>
    </div>

@if (!Model.Ejemplares.Any())
{
    <div class="alert alert-info">
        No hay ejemplares registrados.
    </div>
}
else
{
    var total = Model.Ejemplares.Count;
    var disponibles = Model.Ejemplares.Count(e => e.Disponible && !e.DadoDeBaja);
    var noDisponibles = Model.Ejemplares.Count(e => !e.Disponible && !e.DadoDeBaja);
    var dadosDeBaja = Model.Ejemplares.Count(e => e.DadoDeBaja);

    <div class="tabla-container">

        <table id="tabla-ejemplar" class="tabla-ejemplar">

            <thead>
                <tr>
                    <th>Codigo Ejemplar</th>
                    <th>Libro</th>
                    <th>Estado Conservación</th>
                    <th>Disponible</th>
                    <th>Dado de Baja</th>
                    <th>Ubicación</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>

            @foreach (var ejemplar in Model.Ejemplares)
            {
                <tr class="@(ejemplar.DadoDeBaja ? "fila-baja" : "")">

                    <td>
                        <strong>@ejemplar.CodigoInventario</strong>
                    </td>

                    <td>
                        @if (Model.LibrosTitulos.TryGetValue(ejemplar.LibroId, out var tituloLibro))
                        {
                            <span>@tituloLibro</span>
                        }
                        else
                        {
                            <span class="text-muted">Libro #@ejemplar.LibroId</span>
                        }
                    </td>

                    <td>@(ejemplar.EstadoConservacion ?? "N/A")</td>

                    <td>
                        @if (ejemplar.Disponible)
                        {
                            <span class="estado activo">Disponible</span>
                        }
                        else
                        {
                            <span class="estado inactivo">No disponible</span>
                        }
                    </td>

                    <td>
                        @if (ejemplar.DadoDeBaja)
                        {
                            <span class="estado baja">Baja</span>

                            @if (!string.IsNullOrEmpty(ejemplar.MotivoBaja))
                            {
                                <br />
                                <small class="text-muted">@ejemplar.MotivoBaja</small>
                            }
                        }
                        else
                        {
                            <span class="estado activo">No</span>
                        }
                    </td>

                    <td>@(ejemplar.Ubicacion ?? "N/A")</td>

                    <td>
                        @if (ejemplar.Estado)
                        {
                            <span class="estado activo">Activo</span>
                        }
                        else
                        {
                            <span class="estado inactivo">Inactivo</span>
                        }
                    </td>

                    <td class="acciones">

                        <a href="/Ejemplar/Edit/@ejemplar.RouteToken"
                            class="btn-editar">

                            <img src="~/assets/icons/edit_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                    class="icono-btn">

                            Editar
                        </a>

                        <a href="/Ejemplar/Delete/@ejemplar.RouteToken"
                            class="btn-eliminar">

                            <img src="~/assets/icons/delete_24dp_E3E3E3_FILL0_wght400_GRAD0_opsz24.svg"
                                    class="icono-btn">

                            Eliminar
                        </a>

                    </td>

                </tr>
            }

                <tr id="fila-sin-resultados" style="display:none;">
                    <td colspan="8" style="text-align:center; padding:20px; color:#9ca3af;">
                        No hay ejemplares que coincidan con la busqueda.
                    </td>
                </tr>
            </tbody>

        </table>

    </div>

    <div class="estadisticas">

        <div class="stat stat-info">
            Total ejemplares: @total
        </div>

        <div class="stat stat-success">
            Disponibles: @disponibles
        </div>

        <div class="stat stat-warning">
            No disponibles: @noDisponibles
        </div>

        <div class="stat stat-danger">
            Dados de baja: @dadosDeBaja
        </div>

    </div>
}

</div>

@section Scripts {
<script>
    (function () {
        var input = document.getElementById('buscador-ejemplar');
        var select = document.getElementById('orden-ejemplar');
        var tabla = document.getElementById('tabla-ejemplar');

        if (!input || !tabla) return;

        function normalizar(s) {
            return (s || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim();
        }

        function aplicar() {
            var termino = normalizar(input.value);
            var orden = select ? select.value : 'codigo_asc';
            var tbody = tabla.querySelector('tbody');
            var filas = Array.from(tbody.querySelectorAll('tr:not(#fila-sin-resultados)'));

            // Ordenar
            var colIndex = orden.startsWith('titulo') ? 1 : 0;
            var asc = orden.endsWith('_asc');
            filas.sort(function (a, b) {
                var va = normalizar(a.cells[colIndex] ? a.cells[colIndex].textContent : '');
                var vb = normalizar(b.cells[colIndex] ? b.cells[colIndex].textContent : '');
                return asc ? va.localeCompare(vb) : vb.localeCompare(va);
            });
            filas.forEach(function (f) { tbody.appendChild(f); });

            // Filtrar
            var visibles = 0;
            filas.forEach(function (fila) {
                var texto = normalizar(fila.textContent);
                var coincide = termino === '' || texto.includes(termino);
                fila.style.display = coincide ? '' : 'none';
                if (coincide) visibles++;
            });

            var sinResultados = document.getElementById('fila-sin-resultados');
            if (sinResultados) {
                sinResultados.style.display = visibles === 0 ? '' : 'none';
                tbody.appendChild(sinResultados);
            }
        }

        input.addEventListener('input', aplicar);
        if (select) select.addEventListener('change', aplicar);

        aplicar();
    })();
</script>
}